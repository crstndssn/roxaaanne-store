<!-- Global Player Bar -->
<style>
  body {
    padding-bottom: 100px !important;
  }

  #roxy-player {
    display: none;
    position: fixed;
    bottom: 7px;
    left: 20px;
    right: 20px;
    border-radius: 10px;
    z-index: 9999;
    height: 90px;
    background: rgb(33 33 33 / 33%);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  #roxy-player-inner {
    width: 100%;
    display: flex;
    align-items: center;
    height: 100%;
    padding: 0 14px;
    gap: 10px;
  }

  @media (min-width: 640px) {
    #roxy-player-inner {
      padding: 0 20px;
      gap: 16px;
    }
  }

  /* ── Left ── */
  #roxy-player-left {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
    flex: 1;
    max-width: 160px;
  }

  @media (min-width: 640px) {
    #roxy-player-left {
      gap: 10px;
      max-width: 260px;
    }
  }

  #roxy-player-art {
    width: 50px;
    height: 50px;
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
    background: #222;
    display: none;
  }

  #roxy-player-info {
    min-width: 0;
  }

  #roxy-player-title {
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 170px;
  }

  #roxy-player-artist {
    color: rgba(255, 255, 255, 0.45);
    font-size: 11px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 170px;
    margin-top: 2px;
  }

  /* ── Center ── */
  #roxy-player-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 2;
    gap: 6px;
    min-width: 0;
  }

  /* Radio center — only live indicator + progress */
  #roxy-player-radio-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    gap: 6px;
  }

  #roxy-player-live-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  #roxy-player-live-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #cc0000;
    animation: roxy-player-pulse 1.4s ease-in-out infinite;
  }

  @keyframes roxy-player-pulse {
    0,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.4;
      transform: scale(0.8);
    }
  }

  #roxy-player-live-label {
    color: rgba(255, 255, 255, 0.5);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  /* Radio progress (display only, no seek) */
  #roxy-player-radio-bar {
    width: 100%;
    max-width: 480px;
    height: 3px;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 2px;
    position: relative;
  }

  #roxy-player-radio-fill {
    height: 100%;
    width: 0;
    background: #cc0000;
    border-radius: 2px;
    transition: width 0.1s linear;
  }

  /* Music center — full controls */
  #roxy-player-music-center {
    display: none;
    flex-direction: column;
    align-items: center;
    width: 100%;
    gap: 4px;
  }

  #roxy-player-controls {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  #roxy-player-controls button {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    color: rgba(255, 255, 255, 0.65);
  }

  #roxy-player-controls button:hover {
    color: #fff;
  }

  #roxy-player-btn-shuffle,
  #roxy-player-btn-repeat {
    color: rgba(255, 255, 255, 0.35);
  }

  #roxy-player-btn-play {
    background: #fff !important;
    color: #000 !important;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
  }

  #roxy-player-icon-pause {
    display: none;
  }

  #roxy-player-music-progress {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    max-width: 480px;
  }

  #roxy-player-time-cur,
  #roxy-player-time-dur {
    color: rgba(255, 255, 255, 0.35);
    font-size: 10px;
    min-width: 28px;
    font-variant-numeric: tabular-nums;
  }

  #roxy-player-time-cur {
    text-align: right;
  }

  #roxy-player-progress-bar {
    flex: 1;
    height: 3px;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 2px;
    cursor: pointer;
    position: relative;
  }

  #roxy-player-progress-fill {
    height: 100%;
    width: 0;
    background: rgba(255, 255, 255, 0.7);
    border-radius: 2px;
    pointer-events: none;
    transition: width 0.1s linear;
  }

  #roxy-player-progress-bar:hover #roxy-player-progress-fill {
    background: #fff;
  }

  /* ── Right ── */
  #roxy-player-right {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
    position: relative;
  }

  @media (min-width: 640px) {
    #roxy-player-right {
      gap: 12px;
    }
  }

  /* ── Mobile progress strip (top of player bar) ── */
  #roxy-mobile-strip {
    display: none;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px 10px 0 0;
    overflow: hidden;
    pointer-events: none;
  }

  #roxy-mobile-strip-fill {
    height: 100%;
    width: 0;
    background: rgba(255, 255, 255, 0.55);
    transition: width 0.1s linear;
  }

  /* ── Mobile layout (< 640px) ── */
  @media (max-width: 639px) {
    body {
      padding-bottom: 80px !important;
    }

    #roxy-player {
      height: 72px;
      width: 95%;
    }

    #roxy-mobile-strip {
      display: block;
    }

    #roxy-player-inner {
      padding: 0 10px;
      gap: 6px;
      position: relative;
    }

    /* Left: art + info */
    #roxy-player-left {
      flex: 1;
      max-width: none;
      gap: 8px;
    }

    #roxy-player-art {
      width: 36px;
      height: 36px;
    }

    #roxy-player-title {
      font-size: 12px;
      max-width: 120px;
    }

    #roxy-player-artist {
      font-size: 10px;
      max-width: 120px;
    }

    #roxy-player-btn-add {
      display: none !important;
    }

    /* Center: controls only, no progress row */
    #roxy-player-center {
      flex: 0 0 auto;
      gap: 0;
    }

    #roxy-player-radio-center {
      gap: 0;
    }

    /* Hide progress rows on mobile — strip handles it */
    #roxy-player-music-center #roxy-player-music-progress,
    #roxy-player-radio-center #roxy-player-music-progress {
      display: none !important;
    }

    #roxy-player-controls {
      gap: 8px;
    }

    #roxy-player-btn-play {
      width: 30px;
      height: 30px;
    }

    /* Right: only panel toggle */
    #roxy-player-btn-shuffle,
    #roxy-player-btn-repeat,

    #themeToggle {
      display: none !important;
    }

    #roxy-player-right {
      gap: 7px;
    }
  }

  /* Theme toggle */
  #themeToggle {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
    padding: 0;
    display: flex;
    align-items: center;
    transition: transform 0.3s;
    flex-shrink: 0;
  }

  #themeToggle:hover {
    transform: rotate(20deg);
  }

  /* Video panel toggle */
  #roxy-player-btn-videopanel {
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.4);
    padding: 0;
    display: flex;
    align-items: center;
    transition: color 0.15s;
    flex-shrink: 0;
  }

  #roxy-player-btn-videopanel:hover,
  #roxy-player-btn-videopanel.active {
    color: #fff;
  }

  /* Mute button (radio mode only) */
  #roxy-player-btn-mute {
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.5);
    padding: 0;
    display: flex;
    align-items: center;
  }
  #roxy-player-btn-mute:hover {
    color: #fff;
  }

  /* Mode toggle tabs */
  #roxy-player-mode-toggle {
    display: flex;
    align-items: center;
    gap: 2px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 4px;
  }

  .roxy-player-mode-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 5px 6px;
    border-radius: 5px;
    display: flex;
    align-items: center;
    color: rgba(255, 255, 255, 0.35);
    transition: background 0.15s
    , color 0.15s;
  }

  .roxy-player-mode-btn.active {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
  }

  /* Volume popup */
  #roxy-player-volume-wrap {
    display: none;
    position: absolute;
    bottom: 55px;
    right: 0;
    align-items: center;
    background: rgba(33, 33, 33, 0.9);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border-radius: 10px;
    padding: 10px 14px;
    gap: 8px;
  }

  #roxy-player-volume-wrap.open {
    display: flex;
  }

  #roxy-player-volume {
    width: 80px;
    accent-color: white;
    cursor: pointer;
  }

  /* Add to playlist */
  #roxy-player-btn-add {
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    width: 22px;
    height: 22px;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.5);
    font-size: 14px;
    display: none;
    align-items: center;
    justify-content: center;
    line-height: 1;
    flex-shrink: 0;
    transition: border-color 0.15s
    , color 0.15s;
  }

  #roxy-player-btn-add:hover {
    border-color: rgba(255, 255, 255, 0.7);
    color: #fff;
  }
  #roxy-player-btn-add.saved {
    border-color: #1db954;
    color: #1db954;
  }

  /* ── Video panel wrapper (matches player positioning) ── */
  #roxy-video-panel-wrap {
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    position: fixed;
    bottom: 105px;
    left: 20px;
    right: 20px;
    z-index: 9998;
    transition: opacity 0.2s
    , visibility 0.2s;
  }

  #roxy-video-panel-wrap.open {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Video panel ── */
  #roxy-video-panel {
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 -4px 30px rgba(0, 0, 0, 0.5);
    background: rgb(33 33 33 / 33%);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    flex-direction: row;
    display: flex;
    height: 280px;
  }

  #roxy-video-panel.open {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
  }

  /* Left: video */
  #roxy-video-left {
    flex: 0 0 50%;
    position: relative;
    background: #000;
    border-radius: 10px 0 0 10px;
    overflow: hidden;
  }

  #roxy-video-iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  /* Right: recommended */
  #roxy-video-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
    padding: 14px 0;
  }

  #roxy-video-rec-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16px 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  #roxy-video-rec-title {
    color: rgba(255, 255, 255, 0.5);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  #roxy-video-close {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.35);
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
    padding: 2px 4px;
    border-radius: 4px;
    transition: color 0.15s;
  }

  #roxy-video-close:hover {
    color: #fff;
  }

  #roxy-video-rec-list {
    flex: 1;
    overflow-y: auto;
    padding: 6px 0;
  }

  #roxy-video-rec-list::-webkit-scrollbar {
    width: 3px;
  }

  #roxy-video-rec-list::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.15);
    border-radius: 2px;
  }

  .roxy-rec-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 16px;
    cursor: pointer;
    transition: background 0.15s;
    border-radius: 6px;
    margin: 0 6px;
  }

  .roxy-rec-item:hover {
    background: rgba(255, 255, 255, 0.07);
  }

  .roxy-rec-item.playing {
    background: rgba(255, 255, 255, 0.05);
  }

  .roxy-rec-art {
    width: 38px;
    height: 38px;
    border-radius: 5px;
    object-fit: cover;
    flex-shrink: 0;
    background: #333;
  }

  .roxy-rec-info {
    min-width: 0;
    flex: 1;
  }

  .roxy-rec-name {
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .roxy-rec-artist {
    color: rgba(255, 255, 255, 0.4);
    font-size: 11px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 2px;
  }

  .roxy-rec-item.playing .roxy-rec-name {
    color: #1db954;
  }

  /* Radio: panel ocupa todo el ancho (sin video) */
  #roxy-video-panel.radio-mode #roxy-video-left {
    display: none;
  }

  #roxy-video-panel.radio-mode #roxy-video-right {
    flex: 1;
  }

  /* Programa item */
  .roxy-prog-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 8px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .roxy-prog-item:last-child {
    border-bottom: none;
  }

  .roxy-prog-item.current {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 6px;
  }

  .roxy-prog-time {
    color: rgba(255, 255, 255, 0.35);
    font-size: 11px;
    font-variant-numeric: tabular-nums;
    min-width: 38px;
    padding-top: 2px;
    flex-shrink: 0;
  }

  .roxy-prog-item.current .roxy-prog-time {
    color: #cc0000;
  }

  .roxy-prog-title {
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .roxy-prog-item.current .roxy-prog-title {
    color: #fff;
  }

  .roxy-prog-host {
    color: rgba(255, 255, 255, 0.4);
    font-size: 11px;
    margin-top: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

</style>

<!-- Video panel wrapper (same positioning as player bar) -->
<div id="roxy-video-panel-wrap">
  <div id="roxy-video-panel" class="container mx-auto">
    <!-- Left: video (music mode only) -->
    <div id="roxy-video-left">
      <iframe
        id="roxy-video-iframe"
        src=""
        allow="autoplay; encrypted-media"
        allowfullscreen></iframe>
    </div>
    <!-- Right: recommended (music) / programming (radio) -->
    <div id="roxy-video-right">
      <div id="roxy-video-rec-header">
        <span id="roxy-video-rec-title">Recomendadas</span>
        <button
          id="roxy-video-close"
          onclick="rpCloseVideo()"
          title="Ocultar">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg>
        </button>
      </div>
      <div id="roxy-video-rec-list"></div>
    </div>
  </div>
</div>

<div id="roxy-player" class="container mx-auto">
  <div id="roxy-mobile-strip">
    <div id="roxy-mobile-strip-fill"></div>
  </div>
  <div id="roxy-player-inner">

    <!-- Left: art + info + add button -->
    <div id="roxy-player-left">
      <img
        id="roxy-player-art"
        src=""
        alt=""
        width="50"
        height="50">
      <div id="roxy-player-info">
        <div id="roxy-player-title"></div>
        <div id="roxy-player-artist"></div>
      </div>
      <button
        id="roxy-player-btn-add"
        onclick="rpAddToPlaylist()"
        title="Guardar en mi lista">+</button>
    </div>

    <!-- Center -->
    <div id="roxy-player-center">

      <!-- Radio: live dot + read-only progress -->
      <div id="roxy-player-radio-center">
        <div id="roxy-player-live-row">
          <span id="roxy-player-live-dot"></span>
          <span id="roxy-player-live-label">RADIO</span>
        </div>
        <div id="roxy-player-music-progress" style="display:flex;">
          <span id="roxy-player-radio-time-cur" style="color:rgba(255,255,255,0.35);font-size:10px;min-width:28px;text-align:right;font-variant-numeric:tabular-nums;">0:00</span>
          <div id="roxy-player-radio-bar">
            <div id="roxy-player-radio-fill"></div>
          </div>
          <span id="roxy-player-radio-time-dur" style="color:rgba(255,255,255,0.35);font-size:10px;min-width:28px;font-variant-numeric:tabular-nums;">0:00</span>
        </div>
      </div>

      <!-- Music: full controls -->
      <div id="roxy-player-music-center">
        <div id="roxy-player-controls">
          <button
            onclick="rpShuffle()"
            id="roxy-player-btn-shuffle"
            title="Aleatorio">
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round">
              <path d="M16 3h5v5M4 20L21 3M21 16v5h-5M15 15l6 6M4 4l5 5" />
            </svg>
          </button>
          <button onclick="rpPrev()">
            <svg
              width="17"
              height="17"
              viewBox="0 0 24 24"
              fill="currentColor">
              <path d="M6 6h2v12H6zm3.5 6l8.5 6V6z" />
            </svg>
          </button>
          <button onclick="rpTogglePlay()" id="roxy-player-btn-play">
            <svg
              id="roxy-player-icon-play"
              width="13"
              height="13"
              viewBox="0 0 14 14"
              fill="currentColor">
              <polygon points="3,1 13,7 3,13" />
            </svg>
            <svg
              id="roxy-player-icon-pause"
              width="13"
              height="13"
              viewBox="0 0 24 24"
              fill="currentColor">
              <rect
                x="6"
                y="4"
                width="4"
                height="16" /><rect
                x="14"
                y="4"
                width="4"
                height="16" />
            </svg>
          </button>
          <button onclick="rpNext()">
            <svg
              width="17"
              height="17"
              viewBox="0 0 24 24"
              fill="currentColor">
              <path d="M6 18l8.5-6L6 6v12zm2-8.14L11.03 12 8 14.14V9.86zM16 6h2v12h-2z" />
            </svg>
          </button>
          <button
            onclick="rpToggleRepeat()"
            id="roxy-player-btn-repeat"
            title="Repetir">
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round">
              <path d="M17 1l4 4-4 4" /><path d="M3 11V9a4 4 0 014-4h14M7 23l-4-4 4-4" />
              <path d="M21 13v2a4 4 0 01-4 4H3" />
            </svg>
          </button>
        </div>
        <div id="roxy-player-music-progress">
          <span id="roxy-player-time-cur">0:00</span>
          <div id="roxy-player-progress-bar" onclick="rpSeek(event)">
            <div id="roxy-player-progress-fill"></div>
          </div>
          <span id="roxy-player-time-dur">0:00</span>
        </div>
      </div>

    </div>

    <!-- Right: volume + mode toggle -->
    <div id="roxy-player-right">
      <!-- Volume popup (toggle on speaker click) -->
      <div id="roxy-player-volume-wrap">
        <input
          id="roxy-player-volume"
          type="range"
          min="0"
          max="1"
          step="0.05"
          value="1"
          oninput="rpVolume(this.value)">
      </div>

      <!-- Video panel toggle (always visible) -->
      <button
        id="roxy-player-btn-videopanel"
        onclick="rpToggleVideopanel()"
        title="Ver panel">
        <!-- Hamburger: shown when no video -->
        <svg
          id="roxy-videopanel-icon-menu"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round">
          <line
            x1="3"
            y1="6"
            x2="21"
            y2="6" />
          <line
            x1="3"
            y1="12"
            x2="21"
            y2="12" />
          <line
            x1="3"
            y1="18"
            x2="21"
            y2="18" />
        </svg>
        <!-- Screen: shown when video available -->
        <svg
