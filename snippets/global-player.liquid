</div>

<!-- Two separate audio elements -->
<audio id="roxy-player-audio-radio" style="display:none;"></audio>
<audio id="roxy-player-audio-music" style="display:none;"></audio>

<script>
  var RP = {
    radioQueue: [],
    queue: [],
    recommended: [],
    radioProgram: [],
    radioProgramIdx: -1,
    myPlaylist: [],
    radioIdx: 0,
    musicIdx: -1,
    uiMode: 'radio',
    isShuffle: false,
    isRepeat: false,
    radioAudio: null,
    musicAudio: null,
    _radioStarted: false,
    isIOS: /iPad|iPhone|iPod/.test(navigator.userAgent) || (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1),

    init: function() {
      RP.radioAudio = document.getElementById('roxy-player-audio-radio');
      RP.musicAudio = document.getElementById('roxy-player-audio-music');

      // Radio audio: always loops through queue
      RP.radioAudio.addEventListener('ended', function() { RP.radioNext(); });
      RP.radioAudio.addEventListener('timeupdate', function() { RP.onRadioTimeUpdate(); });

      // Music audio events
      RP.musicAudio.addEventListener('ended', function() {
        if (RP.isRepeat) { RP.musicAudio.play(); return; }
        // Last track without shuffle → switch back to radio
        if (!RP.isShuffle && RP.musicIdx >= RP.queue.length - 1) {
          RP.applyUiMode('radio');
          RP.saveState();
          return;
        }
        RP.musicNext();
      });
      RP.musicAudio.addEventListener('timeupdate', function() { RP.onMusicTimeUpdate(); });
      RP.musicAudio.addEventListener('play', function() { RP.setPlayIcon(true); });
      RP.musicAudio.addEventListener('pause', function() { RP.setPlayIcon(false); });

      // Load personal playlist
      try { RP.myPlaylist = JSON.parse(localStorage.getItem('rp_myplaylist') || '[]'); } catch(e) {}

      var metafieldRadioQueue = RP.radioQueue.slice();

      // Pick a random starting point in the program on each page load
      if (RP.radioProgram.length > 0) {
        RP.radioProgramIdx = Math.floor(Math.random() * RP.radioProgram.length);
      }

      var restored = false;

      // Restore session
      try {
        var saved = sessionStorage.getItem('rp_state');
        if (saved) {
          var s = JSON.parse(saved);
          RP.radioQueue = metafieldRadioQueue.length > 0 ? metafieldRadioQueue : (s.radioQueue || []);
          RP.queue = s.queue || [];
          RP.radioIdx = s.radioIdx || 0;
          RP.musicIdx = s.musicIdx != null ? s.musicIdx : -1;
          RP.uiMode = s.uiMode || 'radio';
          RP.isShuffle = s.isShuffle || false;
          RP.isRepeat = s.isRepeat || false;

          if (RP.isShuffle) document.getElementById('roxy-player-btn-shuffle').style.color = '#fff';
          if (RP.isRepeat) document.getElementById('roxy-player-btn-repeat').style.color = '#fff';
          if (!RP.isIOS) {
            if (s.radioVolume != null) RP.radioAudio.volume = s.radioVolume;
            if (s.musicVolume != null) RP.musicAudio.volume = s.musicVolume;
          }

          RP.applyUiMode(RP.uiMode);

          // Start radio (always, it runs in background)
          if (RP.radioQueue.length > 0) {
            RP.startRadio(s.radioTime || 0);
          }

          // Restore music track info (don't autoplay unless in music mode)
          if (RP.queue.length > 0 && RP.musicIdx >= 0) {
            if (RP.uiMode === 'music') {
              RP.renderMusicTrack(RP.musicIdx, false);
              if (s.musicTime) {
                RP.musicAudio.addEventListener('loadeddata', function onLoad() {
                  RP.musicAudio.removeEventListener('loadeddata', onLoad);
                  RP.musicAudio.currentTime = s.musicTime || 0;
                  RP.musicAudio.play().catch(function() { RP.setPlayIcon(false); });
                }, { once: true });
              }
            }
          }

          document.getElementById('roxy-player').style.display = 'flex';
          restored = true;
        }
      } catch(e) {
        // Corrupted session — clear it
        try { sessionStorage.removeItem('rp_state'); } catch(x) {}
      }

      // No valid session — start fresh with radio at a random track + random position
      if (!restored) {
        RP.radioQueue = metafieldRadioQueue;
        if (RP.radioQueue.length > 0) {
          RP.radioIdx = Math.floor(Math.random() * RP.radioQueue.length);
          RP.applyUiMode('radio');
          // Start at a random time — we don't know duration yet so we pass -1 as sentinel
          RP.startRadio(-1);
          document.getElementById('roxy-player').style.display = 'flex';
        }
      }

      // If autoplay was blocked, retry on first user interaction
      if (RP.radioQueue.length > 0) {
        var retryPlay = function() {
          if (RP.radioAudio.paused && RP.radioAudio.src) {
            RP.radioAudio.play().catch(function() {});
          }
          document.removeEventListener('click', retryPlay);
          document.removeEventListener('touchstart', retryPlay);
        };
        document.addEventListener('click', retryPlay, { once: true });
        document.addEventListener('touchstart', retryPlay, { once: true });
      }

      // Always listen for album queue from article pages
      window.addEventListener('roxy:load-queue', function(e) {
        rpCloseVideo();
        RP.queue = e.detail.queue;
        RP.recommended = e.detail.recommended || [];
        RP.musicIdx = e.detail.startIndex || 0;
        RP.renderMusicTrack(RP.musicIdx, true);
        RP.applyUiMode('music');
        document.getElementById('roxy-player').style.display = 'flex';
        RP.saveState();
      });

      // Open video panel from track (video-only tracks)
      window.addEventListener('roxy:open-video', function(e) {
        var embedUrl = rpYoutubeEmbed(e.detail.youtube);
        if (!embedUrl) return;
        document.getElementById('roxy-video-iframe').src = embedUrl;
        rpOpenVideo();
      });
    },

    startRadio: function(fromTime) {
      if (!RP.radioQueue.length) return;
      if (RP.radioIdx >= RP.radioQueue.length) RP.radioIdx = 0;
      var t = RP.radioQueue[RP.radioIdx];
      if (!t || !t.audio) return;

      RP.radioAudio.src = t.audio;
      RP.radioAudio.muted = (RP.uiMode === 'music');
      RP.radioAudio.load();

      RP.radioAudio.addEventListener('loadeddata', function onLoad() {
        RP.radioAudio.removeEventListener('loadeddata', onLoad);
        var dur = RP.radioAudio.duration;
        if (fromTime === -1 && dur && isFinite(dur)) {
          // Random position within the track
          RP.radioAudio.currentTime = Math.random() * dur;
        } else if (fromTime > 0 && dur && fromTime < dur) {
          RP.radioAudio.currentTime = fromTime;
        }
        RP.radioAudio.play().catch(function() {
          RP._radioStarted = false;
        });
        RP._radioStarted = true;
      }, { once: true });

      // Always show track info
      RP.renderRadioTrackInfo(t);
    },

    radioNext: function() {
      RP.radioIdx = (RP.radioIdx + 1) % RP.radioQueue.length;
      RP.startRadio(0);
      RP.saveState();
    },

    renderRadioTrackInfo: function(t) {
      document.getElementById('roxy-player-title').textContent = t.title || '';
      document.getElementById('roxy-player-artist').textContent = t.artist || '';
      var art = document.getElementById('roxy-player-art');
      if (t.art) { art.src = t.art; art.style.display = 'block'; }
      else { art.style.display = 'none'; }
      // Refresh panel if open and in radio mode
      if (RP.uiMode === 'radio' && document.getElementById('roxy-video-panel-wrap').classList.contains('open')) {
        rpRenderRadioProgram();
      }
    },

    renderMusicInfo: function(idx) {
      var t = RP.queue[idx];
      if (!t) return;
      document.getElementById('roxy-player-title').textContent = t.title || '';
      document.getElementById('roxy-player-artist').textContent = t.artist || '';
      var art = document.getElementById('roxy-player-art');
      if (t.art) { art.src = t.art; art.style.display = 'block'; }
      else { art.style.display = 'none'; }
      var isSaved = RP.myPlaylist.some(function(x) { return x.audio === t.audio; });
      var addBtn = document.getElementById('roxy-player-btn-add');
      addBtn.classList.toggle('saved', isSaved);
      addBtn.textContent = isSaved ? '✓' : '+';
    },

    renderMusicTrack: function(idx, autoplay) {
      RP.renderMusicInfo(idx);
      var t = RP.queue[idx];
      if (!t) return;
      rpUpdatePanelIcon(!!(t.youtube));
      RP.musicAudio.src = t.audio || '';
      if (autoplay && t.audio) { RP.musicAudio.play(); }
    },

    applyUiMode: function(mode) {
      RP.uiMode = mode;
      var isRadio = mode === 'radio';
      document.getElementById('roxy-mobile-strip-fill').style.width = isRadio ? '0' : document.getElementById('roxy-player-progress-fill').style.width;
      document.getElementById('roxy-player-radio-center').style.display = isRadio ? 'flex' : 'none';
      document.getElementById('roxy-player-music-center').style.display = isRadio ? 'none' : 'flex';
      document.getElementById('roxy-player-btn-add').style.display = isRadio ? 'none' : 'flex';
      document.getElementById('roxy-player-tab-radio').classList.toggle('active', isRadio);
      document.getElementById('roxy-player-tab-music').classList.toggle('active', !isRadio);
      // Close volume popup on mode switch
      document.getElementById('roxy-player-volume-wrap').classList.remove('open');
      // Radio never pauses — only muted when in music mode
      if (isRadio) {
        RP.radioAudio.muted = false;
        if (!RP.musicAudio.paused) RP.musicAudio.pause();
        // If radio stopped or never started, restart it
        if (RP.radioAudio.paused && RP.radioQueue.length > 0) {
          RP.startRadio(0);
        }
      } else {
        RP.radioAudio.muted = true;
      }
      // Update volume slider and icon to match current mode
      if (RP.isIOS) {
        var currentAudio = isRadio ? RP.radioAudio : RP.musicAudio;
        document.getElementById('roxy-player-icon-sound').style.display = currentAudio.muted ? 'none' : 'block';
        document.getElementById('roxy-player-icon-muted').style.display = currentAudio.muted ? 'block' : 'none';
      } else {
        var vol = isRadio ? RP.radioAudio.volume : RP.musicAudio.volume;
        document.getElementById('roxy-player-volume').value = vol;
        var volMuted = vol === 0;
        document.getElementById('roxy-player-icon-sound').style.display = volMuted ? 'none' : 'block';
        document.getElementById('roxy-player-icon-muted').style.display = volMuted ? 'block' : 'none';
      }
      // Show correct track info (info only — never touch audio src here)
      if (isRadio && RP.radioQueue[RP.radioIdx]) {
        RP.renderRadioTrackInfo(RP.radioQueue[RP.radioIdx]);
      } else if (!isRadio && RP.queue[RP.musicIdx]) {
        RP.renderMusicInfo(RP.musicIdx);
      }
      // Update panel content if open
      if (document.getElementById('roxy-video-panel-wrap').classList.contains('open')) {
        rpRefreshPanel();
      }
    },

    setPlayIcon: function(playing) {
      document.getElementById('roxy-player-icon-play').style.display = playing ? 'none' : 'block';
      document.getElementById('roxy-player-icon-pause').style.display = playing ? 'block' : 'none';
    },

    onRadioTimeUpdate: function() {
      var a = RP.radioAudio;
      if (!a.duration) return;
      var pct = (a.currentTime / a.duration) * 100;
      document.getElementById('roxy-player-radio-fill').style.width = pct + '%';
      document.getElementById('roxy-mobile-strip-fill').style.width = pct + '%';
      document.getElementById('roxy-player-radio-time-cur').textContent = RP.fmt(a.currentTime);
      document.getElementById('roxy-player-radio-time-dur').textContent = RP.fmt(a.duration);
      if (!RP._saveTimer) {
        RP._saveTimer = setTimeout(function() { RP._saveTimer = null; RP.saveState(); }, 5000);
      }
    },

    onMusicTimeUpdate: function() {
      var a = RP.musicAudio;
      if (!a.duration) return;
      var pct = (a.currentTime / a.duration) * 100;
      document.getElementById('roxy-player-progress-fill').style.width = pct + '%';
      document.getElementById('roxy-mobile-strip-fill').style.width = pct + '%';
      document.getElementById('roxy-player-time-cur').textContent = RP.fmt(a.currentTime);
      document.getElementById('roxy-player-time-dur').textContent = RP.fmt(a.duration);
    },

    musicNext: function() {
      if (!RP.queue.length) return;
      var idx = RP.isShuffle
        ? Math.floor(Math.random() * RP.queue.length)
        : (RP.musicIdx + 1) % RP.queue.length;
      RP.musicIdx = idx;
      RP.renderMusicTrack(idx, true);
      RP.saveState();
    },

    musicPrev: function() {
      if (!RP.queue.length) return;
      if (RP.musicAudio.currentTime > 3) { RP.musicAudio.currentTime = 0; return; }
      var idx = (RP.musicIdx - 1 + RP.queue.length) % RP.queue.length;
      RP.musicIdx = idx;
      RP.renderMusicTrack(idx, true);
      RP.saveState();
    },

    saveState: function() {
      try {
        sessionStorage.setItem('rp_state', JSON.stringify({
          radioQueue: RP.radioQueue,
          queue: RP.queue,
          radioIdx: RP.radioIdx,
          musicIdx: RP.musicIdx,
          uiMode: RP.uiMode,
          isShuffle: RP.isShuffle,
          isRepeat: RP.isRepeat,
          radioTime: RP.radioAudio ? RP.radioAudio.currentTime : 0,
          musicTime: RP.musicAudio ? RP.musicAudio.currentTime : 0,
          radioVolume: RP.radioAudio ? RP.radioAudio.volume : 1,
          musicVolume: RP.musicAudio ? RP.musicAudio.volume : 1
        }));
      } catch(e) {}
    },

    fmt: function(s) {
      if (!s || isNaN(s)) return '0:00';
      var m = Math.floor(s / 60), sec = Math.floor(s % 60);
      return m + ':' + (sec < 10 ? '0' : '') + sec;
    }
  };

  function rpSetMode(mode) {
    RP.applyUiMode(mode);
    RP.saveState();
  }
  function rpToggleVolume() {
    var audio = RP.uiMode === 'radio' ? RP.radioAudio : RP.musicAudio;
    audio.muted = !audio.muted;
    var isMuted = audio.muted;
    document.getElementById('roxy-player-icon-sound').style.display = isMuted ? 'none' : 'block';
    document.getElementById('roxy-player-icon-muted').style.display = isMuted ? 'block' : 'none';
    if (!RP.isIOS) {
      document.getElementById('roxy-player-volume').value = isMuted ? 0 : audio.volume;
    }
  }
  function rpTogglePlay() {
    if (RP.musicAudio.paused) RP.musicAudio.play();
    else { RP.musicAudio.pause(); RP.saveState(); }
  }
  function rpNext() { RP.musicNext(); }
  function rpPrev() { RP.musicPrev(); }
  function rpVolume(v) {
    var vol = parseFloat(v);
    if (RP.isIOS) {
      // iOS: can't set volume, use mute instead
      var audio = RP.uiMode === 'radio' ? RP.radioAudio : RP.musicAudio;
      audio.muted = vol === 0;
    } else {
      if (RP.uiMode === 'radio') {
        RP.radioAudio.volume = vol;
      } else {
        RP.musicAudio.volume = vol;
      }
    }
    var isMuted = vol === 0;
    document.getElementById('roxy-player-icon-sound').style.display = isMuted ? 'none' : 'block';
    document.getElementById('roxy-player-icon-muted').style.display = isMuted ? 'block' : 'none';
  }
  function rpShuffle() {
    RP.isShuffle = !RP.isShuffle;
    document.getElementById('roxy-player-btn-shuffle').style.color = RP.isShuffle ? '#fff' : 'rgba(255,255,255,0.35)';
    RP.saveState();
  }
  function rpToggleRepeat() {
    RP.isRepeat = !RP.isRepeat;
    document.getElementById('roxy-player-btn-repeat').style.color = RP.isRepeat ? '#fff' : 'rgba(255,255,255,0.35)';
    RP.saveState();
  }
  function rpSeek(e) {
    var bar = document.getElementById('roxy-player-progress-bar');
    if (RP.musicAudio.duration) RP.musicAudio.currentTime = (e.offsetX / bar.offsetWidth) * RP.musicAudio.duration;
  }
  function rpYoutubeEmbed(url) {
    if (!url) return '';
    var m = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?(?:.*&)?v=|embed\/|shorts\/))([^?&\s]+)/);
    return m ? 'https://www.youtube.com/embed/' + m[1] + '?autoplay=1' : '';
  }


  function rpCloseVideo() {
    document.getElementById('roxy-video-panel-wrap').classList.remove('open');
    document.getElementById('roxy-player-btn-videopanel').classList.remove('active');
    document.getElementById('roxy-player-btn-mute').style.display = '';
  }

  function rpOpenVideo() {
    rpRefreshPanel();
    document.getElementById('roxy-video-panel-wrap').classList.add('open');
    document.getElementById('roxy-player-btn-videopanel').classList.add('active');
    var t = RP.queue[RP.musicIdx];
    var hasVideo = RP.uiMode === 'music' && !!(t && t.youtube);
    if (hasVideo) {
      document.getElementById('roxy-player-btn-mute').style.display = 'none';
      document.getElementById('roxy-player-volume-wrap').classList.remove('open');
    }
  }

  function rpToggleVideopanel() {
    var wrap = document.getElementById('roxy-video-panel-wrap');
    if (wrap.classList.contains('open')) {
      rpCloseVideo();
    } else {
      rpOpenVideo();
    }
  }

  function rpUpdatePanelIcon(hasVideo) {
    document.getElementById('roxy-videopanel-icon-menu').style.display = hasVideo ? 'none' : 'block';
    document.getElementById('roxy-videopanel-icon-video').style.display = hasVideo ? 'block' : 'none';
  }

  function rpRefreshPanel() {
    var panel = document.getElementById('roxy-video-panel');
    var isRadio = RP.uiMode === 'radio';
    var title = document.getElementById('roxy-video-rec-title');

    if (isRadio) {
      panel.classList.add('radio-mode');
      document.getElementById('roxy-video-iframe').src = '';
      title.textContent = 'Programación';
      rpUpdatePanelIcon(false);
      document.getElementById('roxy-player-btn-mute').style.display = '';
      rpRenderRadioProgram();
    } else {
      panel.classList.remove('radio-mode');
      title.textContent = 'Recomendadas';
      var t = RP.queue[RP.musicIdx];
      var hasVideo = !!(t && t.youtube);
      rpUpdatePanelIcon(hasVideo);
      // Show/hide volume based on whether there's a real video
      document.getElementById('roxy-player-btn-mute').style.display = hasVideo ? 'none' : '';
      if (hasVideo) {
        document.getElementById('roxy-player-volume-wrap').classList.remove('open');
        var iframe = document.getElementById('roxy-video-iframe');
        if (!iframe.src || iframe.src === window.location.href) {
          iframe.src = rpYoutubeEmbed(t.youtube);
        }
      } else {
        document.getElementById('roxy-video-iframe').src = '';
      }
      rpRenderRecommended();
    }
  }

  function rpRenderRadioProgram() {
    var list = document.getElementById('roxy-video-rec-list');
    list.innerHTML = '';

    // ── If radioProgram metafield is configured, use it ──
    var prog = RP.radioProgram;
    if (prog && prog.length) {
      var currentIdx = RP.radioProgramIdx >= 0 ? RP.radioProgramIdx : 0;
      prog.forEach(function(p, i) {
        var isCurrent = i === currentIdx;
        var isPast = i < currentIdx;
        var el = document.createElement('div');
        el.className = 'roxy-prog-item' + (isCurrent ? ' current' : '');
        if (isPast) el.style.opacity = '0.3';
        el.innerHTML =
          '<div class="roxy-prog-time">' + (p.time || '') + '</div>' +
          '<div style="min-width:0;flex:1;">' +
            '<div class="roxy-prog-title">' +
              (isCurrent ? '<span style="display:inline-block;width:6px;height:6px;border-radius:50%;background:#cc0000;margin-right:5px;vertical-align:middle;animation:roxy-player-pulse 1.4s ease-in-out infinite;"></span>' : '') +
              (p.title || '') +
            '</div>' +
            (p.host ? '<div class="roxy-prog-host">' + p.host + '</div>' : '') +
          '</div>';
        list.appendChild(el);
        if (isCurrent) setTimeout(function() { el.scrollIntoView({ block: 'nearest' }); }, 50);
      });
      return;
    }

    // ── Fallback: use radioQueue to show past / now / upcoming ──
    var queue = RP.radioQueue;
    if (!queue || !queue.length) {
      list.innerHTML = '<p style="color:rgba(255,255,255,0.25);font-size:11px;padding:16px;text-align:center;">Sin programación disponible</p>';
      return;
    }

    var cur = RP.radioIdx;
    var currentEl;

    queue.forEach(function(t, i) {
      var isCurrent = i === cur;
      var isPast = i < cur;
      var el = document.createElement('div');
      el.style.cssText = 'display:flex;align-items:center;gap:10px;padding:8px 16px;border-radius:6px;margin:0 6px;transition:background 0.15s;' +
        (isCurrent ? 'background:rgba(255,255,255,0.06);' : '') +
        (isPast ? 'opacity:0.35;' : '');

      el.innerHTML =
        (t.art
          ? '<img src="' + t.art + '" style="width:36px;height:36px;border-radius:5px;object-fit:cover;flex-shrink:0;background:#333;">'
          : '<div style="width:36px;height:36px;border-radius:5px;background:#333;flex-shrink:0;"></div>') +
        '<div style="min-width:0;flex:1;">' +
          (isCurrent
            ? '<div style="display:flex;align-items:center;gap:5px;margin-bottom:2px;">' +
                '<span style="width:5px;height:5px;border-radius:50%;background:#cc0000;display:inline-block;flex-shrink:0;animation:roxy-player-pulse 1.4s ease-in-out infinite;"></span>' +
                '<span style="color:rgba(255,255,255,0.4);font-size:9px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;">AHORA</span>' +
              '</div>'
            : (isPast
                ? '<div style="color:rgba(255,255,255,0.3);font-size:9px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:2px;">Anterior</div>'
                : '<div style="color:rgba(255,255,255,0.3);font-size:9px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:2px;">A continuación</div>'
              )
          ) +
          '<div style="color:' + (isCurrent ? '#fff' : 'rgba(255,255,255,0.65)') + ';font-size:12px;font-weight:' + (isCurrent ? '600' : '500') + ';white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + (t.title || '') + '</div>' +
          (t.artist ? '<div style="color:rgba(255,255,255,0.4);font-size:11px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px;">' + t.artist + '</div>' : '') +
        '</div>';

      list.appendChild(el);
      if (isCurrent) currentEl = el;
    });

    if (currentEl) setTimeout(function() { currentEl.scrollIntoView({ block: 'nearest' }); }, 50);
  }

  function rpRenderRecommended() {
    var list = document.getElementById('roxy-video-rec-list');
    list.innerHTML = '';
    var tracks = RP.recommended;
    if (!tracks || !tracks.length) {
      list.innerHTML = '<p style="color:rgba(255,255,255,0.25);font-size:11px;padding:16px;text-align:center;">Sin recomendadas</p>';
      return;
    }
    tracks.forEach(function(t, i) {
      var el = document.createElement('div');
      el.className = 'roxy-rec-item';
      el.innerHTML = (t.art ? '<img class="roxy-rec-art" src="' + t.art + '" alt="">' : '<div class="roxy-rec-art"></div>') +
        '<div class="roxy-rec-info">' +
          '<div class="roxy-rec-name">' + (t.title || '') + '</div>' +
          '<div class="roxy-rec-artist">' + (t.artist || '') + '</div>' +
        '</div>';
      el.addEventListener('click', function() { rpPlayRecommended(i); });
      list.appendChild(el);
    });
  }

  function rpPlayRecommended(i) {
    var t = RP.recommended[i];
    if (!t) return;
    // Mark active
    document.querySelectorAll('.roxy-rec-item').forEach(function(el, idx) {
      el.classList.toggle('playing', idx === i);
    });
    // Load into music player
    document.getElementById('roxy-player-title').textContent = t.title || '';
    document.getElementById('roxy-player-artist').textContent = t.artist || '';
    var art = document.getElementById('roxy-player-art');
    if (t.art) { art.src = t.art; art.style.display = 'block'; } else { art.style.display = 'none'; }
    RP.musicAudio.src = t.audio || '';
    if (t.audio) RP.musicAudio.play();
    // Update video iframe if panel is open
    if (document.getElementById('roxy-video-panel-wrap').classList.contains('open')) {
      if (t.youtube) {
        document.getElementById('roxy-video-iframe').src = rpYoutubeEmbed(t.youtube);
      } else {
        document.getElementById('roxy-video-iframe').src = '';
      }
    }
  }

  function rpAddToPlaylist() {
    var t = RP.queue[RP.musicIdx];
    if (!t) return;
    var i = RP.myPlaylist.findIndex(function(x) { return x.audio === t.audio; });
    if (i >= 0) RP.myPlaylist.splice(i, 1);
    else RP.myPlaylist.push({ title: t.title, artist: t.artist, art: t.art, audio: t.audio });
    try { localStorage.setItem('rp_myplaylist', JSON.stringify(RP.myPlaylist)); } catch(e) {}
    RP.renderMusicInfo(RP.musicIdx);
  }

  // Load radio queue from metafield
  {% if shop.metafields.custom.radio_queue %}
    try { RP.radioQueue = {{ shop.metafields.custom.radio_queue.value | json }}; } catch(e) {}
  {% endif %}

  // Load radio programming from metafield
  {% if shop.metafields.custom.radio_program %}
    try {
      {% if shop.metafields.custom.radio_program.type == 'json' %}
        RP.radioProgram = {{ shop.metafields.custom.radio_program.value | json }};
      {% else %}
        RP.radioProgram = JSON.parse({{ shop.metafields.custom.radio_program.value | json }});
      {% endif %}
    } catch(e) { console.warn('radio_program metafield error:', e); }
  {% else %}
    console.warn('radio_program metafield not found. Create it at: Shopify Admin → Settings → Custom data → Shops → Add definition → namespace: custom, key: radio_program, type: JSON');
  {% endif %}

  document.addEventListener('DOMContentLoaded', function() {
    RP.init();
    // Close volume popup on outside click
    document.addEventListener('click', function(e) {
      if (!e.target.closest('#roxy-player-volume-wrap') && !e.target.closest('#roxy-player-btn-mute')) {
        document.getElementById('roxy-player-volume-wrap').classList.remove('open');
      }
      // Hide video panel on outside click (video keeps playing)
      // Exclude the toggle button itself — it has its own handler
      if (
        !e.target.closest('#roxy-video-panel-wrap') &&
        !e.target.closest('.music-track-row') &&
        !e.target.closest('#roxy-player-btn-videopanel')
      ) {
        rpCloseVideo();
      }
    });
  });

  // ── AJAX Navigation ──────────────────────────────────────────────────────────
  // Disabled in Shopify theme editor so section reloads work correctly
  (function() {
    if (window.Shopify && window.Shopify.designMode) return;

    var busy = false;

    function canIntercept(href) {
      try {
        var u = new URL(href, location.href);
        if (u.origin !== location.origin) return false;
        if (/^\/(checkout|cart|account|admin|password)/.test(u.pathname)) return false;
        if (u.pathname === location.pathname && u.hash) return false;
        return true;
      } catch(e) { return false; }
    }

    function runScripts(container) {
      container.querySelectorAll('script').forEach(function(s) {
        var n = document.createElement('script');
        Array.from(s.attributes).forEach(function(a) { n.setAttribute(a.name, a.value); });
        n.textContent = s.textContent;
        s.parentNode.replaceChild(n, s);
      });
    }

    function go(url, push) {
      if (busy) return;
      busy = true;
      // Close cart drawer if it's open
      var cartDrawer = document.querySelector('cart-drawer');
      if (cartDrawer && cartDrawer.classList.contains('active')) {
        cartDrawer.close();
      }
      // Close menu drawer if it's open
      var menuDrawer = document.querySelector('header-drawer');
      if (menuDrawer && menuDrawer.mainDetailsToggle && menuDrawer.mainDetailsToggle.hasAttribute('open')) {
        menuDrawer.mainDetailsToggle.removeAttribute('open');
        menuDrawer.mainDetailsToggle.classList.remove('menu-opening');
        var menuSummary = menuDrawer.mainDetailsToggle.querySelector('summary');
        if (menuSummary) menuSummary.setAttribute('aria-expanded', 'false');
        menuDrawer.mainDetailsToggle.querySelectorAll('details').forEach(function(d) {
          d.removeAttribute('open');
          d.classList.remove('menu-opening');
        });
        menuDrawer.mainDetailsToggle.querySelectorAll('.submenu-open').forEach(function(s) {
          s.classList.remove('submenu-open');
        });
        var bp = menuDrawer.dataset.breakpoint || 'tablet';
        document.body.classList.remove('overflow-hidden-' + bp);
        var header = document.querySelector('.section-header');
        if (header) header.classList.remove('menu-open');
      }
      fetch(url)
        .then(function(r) { return r.text(); })
        .then(function(html) {
          var doc = new DOMParser().parseFromString(html, 'text/html');
          var newMain = doc.getElementById('MainContent');
          var curMain = document.getElementById('MainContent');
          if (newMain && curMain) {
            curMain.innerHTML = newMain.innerHTML;
            runScripts(curMain);
          }
          document.title = doc.title;
          if (push !== false) history.pushState({ url: url }, doc.title, url);
          window.scrollTo(0, 0);
        })
        .catch(function() { location.href = url; })
        .finally(function() { busy = false; });
    }

    document.addEventListener('click', function(e) {
      var a = e.target.closest('a[href]');
      if (!a) return;
      if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
      if (a.target === '_blank' || a.hasAttribute('download')) return;
      var href = a.getAttribute('href');
      if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;
      if (!canIntercept(href)) return;
      e.preventDefault();
      go(href);
    });

    window.addEventListener('popstate', function() { go(location.href, false); });
  })();
</script>