<style>
  .rpr-section { background: #0a0a0a; padding: 80px 0; }

  .rpr-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 36px;
  }
  .rpr-title {
    font-size: clamp(24px, 3.5vw, 40px);
    font-weight: 400; letter-spacing: -1px;
    color: #fff; margin: 0;
  }
  .rpr-view-all {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.2);
    padding-bottom: 1px;
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }
  .rpr-view-all:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.6);
  }

  .rpr-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    gap: 16px;
  }
  @media (min-width: 640px) {
    .rpr-grid { grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr); gap: 24px; }
  }

  .rpr-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-decoration: none;
    color: inherit;
  }
  .rpr-card-img {
    aspect-ratio: 1/1;
    border-radius: 12px;
    overflow: hidden;
    background: #1a1a1a;
    position: relative;
  }
  .rpr-card-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    display: block;
  }
  .rpr-card:hover .rpr-card-img img { transform: scale(1.04); }

  .rpr-card-badge {
    position: absolute;
    top: 10px; left: 10px;
    background: #cc0000;
    color: #fff;
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.06em;
    padding: 3px 8px;
    border-radius: 100px;
  }

  .rpr-card-info { padding: 0 2px; }
  .rpr-card-title {
    font-size: 13px; font-weight: 500;
    color: #fff;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 4px;
  }
  .rpr-card-price {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    display: flex; align-items: center; gap: 6px;
  }
  .rpr-card-price s { font-size: 11px; opacity: 0.6; }
</style>

<section class="rpr-section">
  <div class="container mx-auto px-6 md:px-8">

    {%- assign rpr_col = section.settings.collection -%}
    {%- assign rpr_limit = section.settings.products_count -%}

    <div class="rpr-header">
      <h2 class="rpr-title">{{ section.settings.title }}</h2>
      {%- if rpr_col != blank -%}
        <a href="{{ rpr_col.url }}" class="rpr-view-all">Ver todos →</a>
      {%- endif -%}
    </div>

    {%- if rpr_col != blank -%}
      <div class="rpr-grid">
        {%- for product in rpr_col.products limit: rpr_limit -%}
          <a href="{{ product.url }}" class="rpr-card">
            <div class="rpr-card-img">
              {%- if product.featured_image -%}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy" width="600" height="600">
              {%- endif -%}
              {%- if product.compare_at_price > product.price -%}
                <span class="rpr-card-badge">SALE</span>
              {%- endif -%}
            </div>
            <div class="rpr-card-info">
              <p class="rpr-card-title">{{ product.title }}</p>
              <div class="rpr-card-price">
                {%- if product.compare_at_price > product.price -%}
                  <s>{{ product.compare_at_price | money }}</s>
                {%- endif -%}
                <span>{{ product.price | money }}</span>
              </div>
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p style="color:rgba(255,255,255,0.25);font-size:14px;">Selecciona una colección en los ajustes de esta sección.</p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Productos Recomendados",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "También te puede interesar"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Cantidad de productos",
      "min": 2,
      "max": 12,
      "step": 2,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columnas en escritorio",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columnas en móvil",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    }
  ],
  "presets": [{ "name": "Productos Recomendados" }]
}
{% endschema %}
