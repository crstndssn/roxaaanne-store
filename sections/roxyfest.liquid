<div class="container mx-auto px-6 md:px-10 py-10">
  {% if section.settings.title != blank %}
    <h1 class="text-4xl md:text-5xl font-semibold text-center text-white mb-6">
      {{ section.settings.title }}
    </h1>
  {% endif %}

  {% if section.settings.hero_image != blank %}
    <img
      src="{{ section.settings.hero_image | image_url: width: 2000 }}"
      alt="{{ section.settings.title | escape }}"
      class="w-full h-auto rounded-2xl mb-6">
  {% else %}
    <img
      src="https://cdn.shopify.com/s/files/1/0700/8623/0213/files/flyerfinal2025.jpg?v=1760030715"
      alt="{{ section.settings.title | escape }}"
      class="w-full h-auto rounded-2xl mb-6">
  {% endif %}

  {% if section.settings.intro != blank %}
    <p class="text-white text-lg md:text-xl mb-10">
      {{ section.settings.intro }}
    </p>
  {% endif %}

  {% for block in section.blocks %}
    {% if block.type == 'artist' %}
      {% assign article = articles[block.settings.article] %}
      {% if article %}
        <div class="mb-12" {{ block.shopify_attributes }}>
          {% if block.settings.artist_name != blank %}
            <h2 class="text-3xl font-medium text-white mb-4">
              {{ block.settings.artist_name }}
            </h2>
          {% endif %}

          <a href="{{ article.url }}" class="block">
            {% if article.image %}
              <img
                src="{{ article.image | image_url: width: 2000 }}"
                alt="{{ article.title }}"
                class="w-full h-auto object-cover rounded-xl">
            {% endif %}
          </a>
        </div>
      {% endif %}
    {% endif %}
  {% endfor %}
</div>

{% schema %}
  {
    "name": "Roxy Fest",
    "tag": "section",
    "class": "section roxyfest",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Título",
        "default": "Roxy Fest 2025"
      }, {
        "type": "image_picker",
        "id": "hero_image",
        "label": "Imagen principal"
      }, {
        "type": "textarea",
        "id": "intro",
        "label": "Texto intro",
        "default": "Muchas gracias por ser parte de Roxy Fest, edición 2025; estos fueron unos de los mejores momentos."
      }
    ],
    "blocks": [
      {
        "type": "artist",
        "name": "Artista",
        "settings": [
          {
            "type": "text",
            "id": "artist_name",
            "label": "Nombre del artista"
          }, {
            "type": "article",
            "id": "article",
            "label": "Artículo del artista"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Roxy Fest",
        "category": "Custom"
      }
    ]
  }
{% endschema %}