{% assign active_track = null %}

<!-- Hero -->
<div class="container mx-auto rounded-xl relative flex justify-center items-center overflow-hidden bg-black min-h-[520px] md:min-h-[330px]">
  {% if article.image %}
    <div class="absolute inset-0">
      <img
        src="{{ article.image | image_url: width: 1400 }}"
        alt=""
        class="w-full h-full object-cover opacity-40 blur-xl scale-110">
      <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black"></div>
    </div>
  {% else %}
    <div class="absolute inset-0 bg-gradient-to-b from-zinc-900 to-black"></div>
  {% endif %}

  <div class="relative w-full container mx-auto px-10 md:px-10 pb-10 pt-0 pr-10">
    <!-- Mobile: portada grande centrada arriba -->
    <div class="flex flex-col items-center text-center md:hidden gap-5 mb-4">
      {% if article.image %}
        <img
          src="{{ article.image | image_url: width: 800 }}"
          alt="{{ article.title | escape }}"
          class="w-full max-w-xs object-cover rounded-2xl shadow-2xl"
          style="aspect-ratio:1/1;">
      {% endif %}
      <div class="flex flex-col gap-2">
        <p class="text-white/60 text-lg uppercase tracking-widest">Álbum</p>
        <h1 class="text-white text-4xl font-bold leading-tight">{{ article.title | escape }}</h1>
        <p class="text-white/70 text-base">{{ article.metafields.custom.autor }}</p>
        <p class="text-white/50 text-sm">
          {{ article.published_at | date: '%Y' }}
          {% if section.blocks.size > 0 %}
            &nbsp;·&nbsp; {{ section.blocks | where: 'type', 'track' | size }} tracks
          {% endif %}
        </p>
      </div>
    </div>
    <!-- Desktop: portada + texto en fila -->
    <div class="hidden md:flex flex-row items-end gap-8">
      {% if article.image %}
        <img
          src="{{ article.image | image_url: width: 500 }}"
          alt="{{ article.title | escape }}"
          class="w-[250px] h-[250px] object-cover rounded-xl shadow-2xl flex-shrink-0">
      {% endif %}
      <div class="flex flex-col gap-3">
        <p class="text-white/60 text-xl uppercase tracking-widest">Álbum</p>
        <h1 class="text-white text-7xl font-bold leading-tight">{{ article.title | escape }}</h1>
        <p class="text-white/70 text-2xl">{{ article.metafields.custom.autor }}</p>
        <p class="text-white/50 text-xl">
          {{ article.published_at | date: '%Y' }}
          {% if section.blocks.size > 0 %}
            &nbsp;·&nbsp; {{ section.blocks | where: 'type', 'track' | size }} tracks
          {% endif %}
        </p>
      </div>
    </div>
  </div>
</div>

<!-- Controls -->
<div class="container mx-auto bg-black px-6 md:px-10 py-6 flex items-center gap-4 border-b border-white/10">
  <button onclick="musicPlayAll()" class="flex items-center gap-3 bg-white text-black font-bold px-10 py-4 rounded-full hover:bg-white/90 transition-colors text-lg">
    <svg
      width="20"
      height="20"
      viewBox="0 0 14 14"
      fill="currentColor"><polygon points="2,1 13,7 2,13" /></svg>
    Play
  </button>
  <button onclick="musicShuffle()" class="flex items-center gap-3 bg-white/10 text-white font-bold px-10 py-4 rounded-full hover:bg-white/20 transition-colors text-lg">
    <svg
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"><path d="M16 3h5v5M4 20L21 3M21 16v5h-5M15 15l6 6M4 4l5 5" /></svg>
    Shuffle
  </button>
</div>

<!-- Track list -->
<div class="">
  <div class="container mx-auto px-6 md:px-0">

    <!-- Header row -->
    <div class="hidden md:grid grid-cols-[40px_1fr_1fr_80px_60px] gap-4 px-4 py-5 border-b border-white/10 text-white/40 text-lg uppercase tracking-widest">
      <span>#</span>
      <span>Título</span>
      <span>Artistas</span>
      <span class="text-right">Duración</span>
      <span></span>
    </div>

    {% assign track_index = 0 %}
    {% for block in section.blocks %}
      {% if block.type == 'track' %}
        {% assign track_index = track_index | plus: 1 %}
        <div
          {{ block.shopify_attributes }}
          class="music-track-row grid grid-cols-[40px_1fr_60px] md:grid-cols-[40px_1fr_1fr_80px_60px] gap-4 px-4 py-7 border-b border-white/5 items-center hover:bg-white/5 cursor-pointer rounded-lg transition-colors group{% if block.settings.audio_url == blank and block.settings.youtube_url == blank %} no-audio{% endif %}"
          data-index="{{ track_index }}"
          data-audio="{{ block.settings.audio_url }}"
          data-youtube="{{ block.settings.youtube_url }}"
          data-title="{{ block.settings.track_title | escape }}"
          onclick="musicSelectTrack(this)">

          <span class="track-number text-white/40 text-2xl text-center group-hover:hidden">{{ track_index }}</span>
          <span class="track-play hidden group-hover:flex items-center justify-center text-white">
            {% if block.settings.audio_url == blank and block.settings.youtube_url != blank %}
              <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"><rect
                  x="2"
                  y="3"
                  width="20"
                  height="15"
                  rx="2" /><polygon
                  points="9,8 16,11 9,14"
                  fill="currentColor"
                  stroke="none" /></svg>
            {% else %}
              <svg
                width="12"
                height="12"
                viewBox="0 0 14 14"
                fill="currentColor"><polygon points="2,1 13,7 2,13" /></svg>
            {% endif %}
          </span>

          <div class="flex flex-col min-w-0">
            <span class="track-title text-white text-2xl font-medium truncate">
              {{ block.settings.track_title | default: 'Sin título' }}
            </span>
            {% if block.settings.track_subtitle != blank %}
              <span class="text-white/40 text-lg truncate">{{ block.settings.track_subtitle }}</span>
            {% endif %}
            {% if block.settings.artists != blank %}
              <span class="md:hidden text-white/50 text-lg truncate">{{ block.settings.artists }}</span>
            {% endif %}
          </div>

          <span class="hidden md:block text-white/50 text-2xl truncate">{{ block.settings.artists }}</span>
          <span class="hidden md:block text-white/50 text-2xl text-right">{{ block.settings.duration }}</span>

          <div class="flex items-center justify-end gap-2">
            {% if block.settings.youtube_url != blank %}
              <span class="text-white/30 hover:text-white/70 transition-colors" title="Video disponible">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"><rect
                    x="2"
                    y="4"
                    width="20"
                    height="16"
                    rx="3" /><polygon
                    points="10,9 16,12 10,15"
                    fill="currentColor"
                    stroke="none" /></svg>
              </span>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}

  </div>
</div>


{% if article.content != blank %}
  <div class="bg-black px-6 md:px-10 py-12 container mx-auto prose prose-invert max-w-none">
    {{ article.content }}
  </div>
{% endif %}

<style>
  .music-track-row.is-playing .track-number {
    display: none;
  }
  .music-track-row.is-playing .track-play {
    display: flex !important;
    color: #1db954;
  }
  .music-track-row.is-playing .track-title {
    color: #1db954;
  }
  .music-track-row.no-audio {
    opacity: 0.45;
  }
  .music-track-row.no-audio:hover {
    opacity: 0.7;
  }
</style>

<script>
  var musicTracks = [];
  var musicRecommended = [];

  {% if article.metafields.custom.recommended_tracks %}
    try { musicRecommended = {{ article.metafields.custom.recommended_tracks.value | json }}; } catch(e) {}
  {% endif %}

  document.querySelectorAll('.music-track-row').forEach(function(row, i) {
    musicTracks.push({
      el: row,
      audio: row.dataset.audio,
      youtube: row.dataset.youtube,
      title: row.dataset.title,
      art: '{{ article.image | image_url: width: 200 }}',
      artist: '{{ article.metafields.custom.autor | escape }}',
      index: i
    });
  });

  function musicBuildQueue() {
    return musicTracks.map(function(t) {
      return { title: t.title, artist: t.artist, art: t.art, audio: t.audio, youtube: t.youtube };
    });
  }

  function musicSelectTrack(el) {
    var idx = parseInt(el.dataset.index) - 1;
    var hasAudio = el.dataset.audio && el.dataset.audio.trim() !== '';
    var hasYoutube = el.dataset.youtube && el.dataset.youtube.trim() !== '';
    if (!hasAudio && hasYoutube) {
      // Solo video: despachar queue igual (para info en player) y abrir modal
      musicDispatchQueue(idx);
      window.dispatchEvent(new CustomEvent('roxy:open-video', { detail: { youtube: el.dataset.youtube } }));
      return;
    }
    musicDispatchQueue(idx);
  }

  function musicDispatchQueue(startIndex) {
    var queue = musicBuildQueue();
    window.dispatchEvent(new CustomEvent('roxy:load-queue', {
      detail: { queue: queue, startIndex: startIndex, recommended: musicRecommended }
    }));
    // Highlight playing row
    document.querySelectorAll('.music-track-row').forEach(function(r) { r.classList.remove('is-playing'); });
    if (musicTracks[startIndex]) musicTracks[startIndex].el.classList.add('is-playing');
  }

  function musicPlayAll() {
    musicDispatchQueue(0);
  }

  function musicShuffle() {
    musicDispatchQueue(Math.floor(Math.random() * musicTracks.length));
  }
</script>

{% schema %}
  {
    "name": "Article Music",
    "tag": "section",
    "class": "section",
    "settings": [],
    "blocks": [
      {
        "type": "track",
        "name": "Track",
        "settings": [
          {
            "type": "text",
            "id": "track_title",
            "label": "Título"
          },
          {
            "type": "text",
            "id": "track_subtitle",
            "label": "Subtítulo (opcional)"
          },
          {
            "type": "text",
            "id": "artists",
            "label": "Artistas"
          },
          {
            "type": "text",
            "id": "duration",
            "label": "Duración (ej: 3:24)"
          }, {
            "type": "text",
            "id": "audio_url",
            "label": "URL del audio (mp3, wav...)"
          }, {
            "type": "text",
            "id": "youtube_url",
            "label": "URL de YouTube (opcional)"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Article Music"
      }
    ]
  }
{% endschema %}