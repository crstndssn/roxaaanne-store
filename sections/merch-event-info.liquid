<section class="event-info">
  {% if section.settings.heading != blank %}
    <h2>{{ section.settings.heading }}</h2>
  {% endif %}
  <p>{{ section.settings.date }}</p>
  <p>{{ section.settings.venue }}</p>
  <div>{{ section.settings.description }}</div>
</section>

{% schema %}
{
  "name": "Event Info",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "text", "id": "date", "label": "Date" },
    { "type": "text", "id": "venue", "label": "Venue" },
    { "type": "richtext", "id": "description", "label": "Description" }
  ],
  "presets": [{ "name": "Event Info" }]
}
{% endschema %}