<!-- Initialize Swiper (scoped to this section) -->
<script>
  (function(){
    var script = document.currentScript;
    var root = script && script.previousElementSibling;
    while (root && root.nodeType !== 1) root = root.previousElementSibling;
    var swiperEl = root && root.classList && root.classList.contains('swiper') ? root : (root && root.querySelector ? root.querySelector('.mySwiperEquipo') : null);
    if (!swiperEl) return;

    new Swiper(swiperEl, {
      slidesPerView: 'auto',
      spaceBetween: 16,
      freeMode: true,
      grabCursor: true,
      pagination: {
        el: swiperEl.querySelector('.swiper-pagination'),
        dynamicBullets: true,
        clickable: true
      },
    });
  })();
</script>

