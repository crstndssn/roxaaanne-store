<div class="bg-[#2EFF05] rounded-3xl dart md:py-24">

  <div class="container mx-auto rounded-t-3xl md:rounded-b-3xl dark:rounded-t-2xl text-center flex flex-col justify-center items-center text-[#2EFF05] bg-black py-20 md:py-24">
    <h3 class="stalinist-one-regular text-[#2EFF05] text-[11vw] leading-[11vw] md:text-[10vw] md:leading-[10vw] font-bold m-0">VOLTAJE</h3>
    <p class="stalinist-one-regular text-[#2EFF05] text-[40px] leading-[40px] md:text-[71px] md:leading-[77px] mb-0">LA<br>BO<br>RA<br>TO<br>RIO<br>DE<br>S<span class="text-[#feffee]">Í</span>N<br>TE<br>SIS</p>
    <p class="stalinist-one-regular text-[#feffee] text-[20px] md:leading-[70px] md:text-[70px] mt-10">CARAMALA</p>
    <p class="stalinist-one-regular text-[#2EFF05] text-[20px] leading-[20px] md:leading-[50px] md:text-[50px] mt-4">23 DE ABRIL</p>
    <p class="stalinist-one-regular text-[#2EFF05] text-[20px] md:leading-[50px] md:text-[50px] mt-4">7:00 PM</p>
  </div>

  <div class="container mx-auto px-8 md:px-0 flex flex-col justify-center items-center md:min-h-screen bg-black py-24 md:py-32 md:mt-24 rounded-b-3xl md:rounded-t-3xl">
    <div class="md:w-2/3 w-full flex justify-start">
      <h2 class="stalinist-one-regular text-[#2EFF05] text-[9vw] leading-[10vw] md:text-[5vw] md:leading-[5.2vw] mb-24 ">¿QUÉ<br> ES?<br> VOLTAJE</h2>
    </div>
    <div class="w-full flex justify-center">
      <p class="text-[28px] md:text-[70px] md:leading-[70px] text-center md:w-1/2 uppercase font-semibold text-[#feffee]">es un
        <span class="text-[#2EFF05]">jam electrónico</span>
        en el que puedes experimentar sonidos con sintetizadores</p>
    </div>
  </div>

  <div class="md:min-h-screen bg-[#2EFF05] py-32 md:py-32">
    <div class="container mx-auto px-8 md:px-0 flex flex-col justify-center items-center">
      <div class="md:w-2/3 w-full flex justify-end">
        <h2 class="stalinist-one-regular text-black text-[9vw] leading-[10vw] md:text-[5vw] md:leading-[5.2vw] mb-24 text-right ">¿Y SI NO<br>TENGO<br>UN<br>SINTE?</h2>
      </div>

      <div class="w-full flex flex-col items-center justify-center">
        <p class="text-[28px] md:text-[70px] md:leading-[70px] text-[#feffee] text-center uppercase font-semibold">
          HABRÁ SINTES<br>DISPONIBLES PARA<br>QUE TOQUES</p>
        <p class="text-[28px] md:text-[70px] md:leading-[70px] text-black text-center uppercase font-semibold">
          SIGUIENDO<br>ALGUNAS<br>INSTRUCCIONES
        </p>


      </div>
    </div>


  </div>
  <div id="registro" class="container mx-auto bg-black px-8 md:px-0 flex flex-col justify-center items-center md:min-h-screen pt-24 md:pt-52 pb-20 md:pb-24 rounded-3xl">

    <div class="w-2/3 w-full flex justify-center">
      <h2 class="stalinist-one-regular text-[#2EFF05] text-[7vw] md:text-[5vw] md:leading-[5.2vw] mb-12 md:mb-24">COMPRA TU ENTRADA</h2>
    </div>

    <div class="w-full flex justify-center">
      <div class="w-full max-w-2xl bg-white/5 backdrop-blur-sm border border-[#2EFF05] rounded-3xl p-8 md:p-12 flex flex-col items-center gap-8">

        <p class="stalinist-one-regular text-[#2EFF05] text-[6vw] md:text-[3vw] text-center">{{ product.price | money }}</p>

        {%- form 'product'
          , product
          , class: 'w-full flex flex-col gap-4' -%}
          <input
            type="hidden"
            name="id"
            value="{{ product.selected_or_first_available_variant.id }}">
          <div class="flex items-center justify-center gap-0 border-2 border-[#2EFF05] rounded-xl overflow-hidden">
            <button
              type="button"
              onclick="voltajeQty(-1)"
              class="stalinist-one-regular text-[#2EFF05] text-3xl px-6 py-3 hover:bg-[#2EFF05] hover:text-black transition-colors">−</button>
            <input
              id="voltaje-qty"
              type="number"
              name="quantity"
              value="1"
              min="1"
              class="stalinist-one-regular text-[#2EFF05] text-2xl text-center bg-transparent w-16 py-3 border-0 outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
            <button
              type="button"
              onclick="voltajeQty(1)"
              class="stalinist-one-regular text-[#2EFF05] text-3xl px-6 py-3 hover:bg-[#2EFF05] hover:text-black transition-colors">+</button>
          </div>

          {% comment %}
          <button
            type="submit"
            name="add"
            {% unless product.selected_or_first_available_variant.available %}
            disabled{% endunless %}
            class="w-full stalinist-one-regular text-2xl bg-black text-[#2EFF05] border-2 border-[#2EFF05] py-4 rounded-xl hover:bg-[#0a1a00] transition-colors font-semibold disabled:opacity-50 disabled:cursor-not-allowed">
            {% if product.selected_or_first_available_variant.available %}
              AGREGAR AL CARRITO
            {% else %}
              AGOTADO
            {% endif %}
          </button>
          {% endcomment %}

          {{ form | payment_button }}
        {%- endform -%}

      </div>
    </div>

  </div>

</div>

<!-- Banner fijo inferior -->
<div id="voltaje-sticky-banner" class="fixed bottom-0 left-0 right-0 z-50 bg-black border-t-2 border-[#2EFF05]">
  <!-- Mobile: info + botón full width -->
  <div class="flex flex-col md:hidden">
    <div class="flex items-center justify-between px-10 py-3">
      <div class="flex flex-col leading-tight">
        <span class="stalinist-one-regular text-[#2EFF05] text-xl">23 DE ABRIL · 7:00 PM</span>
        <span class="stalinist-one-regular text-[#feffee] text-base">CARAMALA</span>
      </div>
      <div class="flex items-center border-2 border-[#2EFF05] rounded-xl overflow-hidden">
        <button type="button" onclick="voltajeQty(-1)" class="stalinist-one-regular text-[#2EFF05] text-2xl px-4 py-2 hover:bg-[#2EFF05] hover:text-black transition-colors">−</button>
        <span id="voltaje-qty-display-mobile" class="stalinist-one-regular text-[#2EFF05] text-xl w-10 text-center">1</span>
        <button type="button" onclick="voltajeQty(1)" class="stalinist-one-regular text-[#2EFF05] text-2xl px-4 py-2 hover:bg-[#2EFF05] hover:text-black transition-colors">+</button>
      </div>
    </div>
    <button onclick="voltajeDirectCheckout()" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %} class="stalinist-one-regular text-2xl bg-[#2EFF05] text-black w-full py-6 text-center hover:bg-[#26d904] transition-colors font-semibold disabled:opacity-50 disabled:cursor-not-allowed">
      {% if product.selected_or_first_available_variant.available %}COMPRA TU ENTRADA{% else %}AGOTADO{% endif %}
    </button>
  </div>
  <!-- Desktop: info + botón -->
  <div class="hidden md:flex items-center justify-between gap-6 px-10 py-5">
    <div class="flex flex-col leading-tight">
      <span class="stalinist-one-regular text-[#2EFF05] text-lg">23 DE ABRIL · 7:00 PM</span>
      <span class="stalinist-one-regular text-[#feffee] text-sm">CARAMALA</span>
    </div>
    <div class="flex items-center gap-4">
      <div class="flex items-center border-2 border-[#2EFF05] rounded-xl overflow-hidden">
        <button type="button" onclick="voltajeQty(-1)" class="stalinist-one-regular text-[#2EFF05] text-2xl px-5 py-3 hover:bg-[#2EFF05] hover:text-black transition-colors">−</button>
        <span id="voltaje-qty-display-desktop" class="stalinist-one-regular text-[#2EFF05] text-xl w-12 text-center">1</span>
        <button type="button" onclick="voltajeQty(1)" class="stalinist-one-regular text-[#2EFF05] text-2xl px-5 py-3 hover:bg-[#2EFF05] hover:text-black transition-colors">+</button>
      </div>
      <button onclick="voltajeDirectCheckout()" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %} class="stalinist-one-regular text-2xl bg-[#2EFF05] text-black px-12 py-4 rounded-xl hover:bg-[#26d904] transition-colors font-semibold whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed">
        {% if product.selected_or_first_available_variant.available %}COMPRA TU ENTRADA{% else %}AGOTADO{% endif %}
      </button>
    </div>
  </div>
</div>

<style>
  .stalinist-one-regular {
    font-family: 'Stalinist One'
    , sans-serif;
  }

  .shopify-payment-button__button--unbranded {
    background-color: #2EFF05 !important;
    color: #000 !important;
    font-family: 'Stalinist One'
    , sans-serif !important;
    font-size: 1.5rem !important;
  }

  .shopify-payment-button__button--unbranded:hover {
    background-color: #26d904 !important;
  }
</style>

<script>
  function voltajeQty(delta) {
    var input = document.getElementById('voltaje-qty');
    var val = Math.max(1, parseInt(input.value) + delta);
    input.value = val;
    document.getElementById('voltaje-qty-display-mobile').textContent = val;
    document.getElementById('voltaje-qty-display-desktop').textContent = val;
  }

  function voltajeDirectCheckout() {
    var variantId = {{ product.selected_or_first_available_variant.id }};
    var qty = parseInt(document.getElementById('voltaje-qty').value) || 1;
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: qty })
    }).then(function() {
      window.location.href = '/checkout';
    });
  }
</script>