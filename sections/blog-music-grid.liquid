{%- paginate blog.articles by 24 -%}
<div class="bg-[#feffee] dark:bg-black min-h-screen">
  <div class="container mx-auto px-6 md:px-10 py-12">

    <h1 class="text-2xl md:text-3xl font-semibold text-black dark:text-[#feffee] mb-8">
      {{ blog.title | escape }}
    </h1>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-x-5 gap-y-8">
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}" class="group block">
          <div class="relative w-full aspect-square overflow-hidden rounded-lg mb-3 bg-black/10 dark:bg-white/10">
            {%- if article.image -%}
              <img
                src="{{ article.image | image_url: width: 600 }}"
                alt="{{ article.image.alt | escape | default: article.title | escape }}"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
                width="600"
                height="600">
            {%- else -%}
              <div class="w-full h-full flex items-center justify-center bg-black/10 dark:bg-white/5">
                <span class="text-black/20 dark:text-white/20 text-5xl">♪</span>
              </div>
            {%- endif -%}
          </div>

          <p class="text-black dark:text-[#feffee] font-semibold text-[14px] md:text-[15px] leading-tight mb-1 group-hover:underline line-clamp-2">
            {{ article.title | escape }}
          </p>
          <p class="text-black/50 dark:text-[#feffee]/50 text-[13px]">
            {{ article.author }}
          </p>
          <p class="text-black/40 dark:text-[#feffee]/40 text-[13px]">
            {{ article.published_at | date: '%Y' }}
          </p>
        </a>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      {%- render 'pagination', paginate: paginate -%}
    {%- endif -%}

  </div>
</div>
{%- endpaginate -%}

{% schema %}
{
  "name": "Blog Music Grid",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
