<!-- HERO -->
<div class="container mx-auto py-40 grid grid-cols-1 md:grid-cols-2 items-center gap-10 md:gap-16">

  <!-- Texto -->
  <div>
    <h1 class="text-[15vw] md:text-[9vw] font-medium leading-[.9] tracking-[-2px] md:tracking-[-7px] text-black dark:text-[#feffee] mb-6 md:mb-8">
      nuestro<br><i class="font-light">espacio</i>
    </h1>
    <p class="text-black/60 dark:text-[#feffee]/80 text-base md:text-[20px] max-w-[480px] mb-8 md:mb-12">
      un perfil propio. eventos, diario, música, fotos, film, artículos, merca — todo en un solo lugar.
    </p>
    <div class="flex flex-col sm:flex-row gap-3">
      <a href="#tarifas" class="inline-block bg-black dark:bg-[#feffee] text-[#feffee] dark:text-black text-xl md:text-3xl font-medium px-8 md:px-12 py-4 md:py-5 hover:opacity-80 transition-opacity rounded-xl text-center">
        ver tarifas
      </a>
      <a href="#entrar" class="inline-block border border-black/40 dark:border-[#feffee] text-black dark:text-[#feffee] text-xl md:text-3xl font-medium px-8 md:px-12 py-4 md:py-5 hover:opacity-70 transition-opacity rounded-xl text-center">
        quiero entrar
      </a>
    </div>
  </div>

  <!-- Pricing card — solo desktop -->
  <div class="border border-black/10 dark:border-[#feffee]/10 rounded-2xl p-8 self-center">
    <p class="text-black/40 dark:text-[#feffee]/40 text-xs tracking-[.18em] uppercase mb-6">precios</p>
    <div class="flex flex-col divide-y divide-black/10 dark:divide-[#feffee]/10">
      <div class="flex justify-between items-start py-5 gap-4">
        <div>
          <span class="text-black dark:text-[#feffee] text-2xl">perfil</span>
          <span class="block text-black/50 dark:text-[#feffee]/50 text-sm mt-1">Tu espacio en Roxaaanne. Sin costo, sin fecha de vencimiento.</span>
        </div>
        <span class="text-black dark:text-[#feffee] text-2xl font-semibold shrink-0">gratis</span>
      </div>
      <div class="flex justify-between items-start py-5 gap-4">
        <div>
          <span class="text-black dark:text-[#feffee] text-2xl">subir contenido</span>
          <span class="block text-black/50 dark:text-[#feffee]/50 text-sm mt-1">Música, fotos, diario, artículos y film. Lo actualizas cuando quieras.</span>
        </div>
        <div class="text-right shrink-0">
          <span class="text-black dark:text-[#feffee] text-2xl font-semibold">$20.000</span>
          <span class="block text-black/40 dark:text-[#feffee]/40 text-sm">/ 3 meses</span>
        </div>
      </div>
      <div class="flex justify-between items-start py-5 gap-4">
        <div>
          <span class="text-black dark:text-[#feffee] text-2xl">boletería</span>
          <span class="block text-black/50 dark:text-[#feffee]/50 text-sm mt-1">Vende tiquetes para tus eventos. Solo cobramos cuando vendes.</span>
        </div>
        <span class="text-black dark:text-[#feffee] text-2xl font-semibold shrink-0">10%</span>
      </div>
      <div class="flex justify-between items-start py-5 gap-4">
        <div>
          <span class="text-black dark:text-[#feffee] text-2xl">merca</span>
          <span class="block text-black/50 dark:text-[#feffee]/50 text-sm mt-1">Vende productos físicos en la tienda. Solo cobramos cuando vendes.</span>
        </div>
        <span class="text-black dark:text-[#feffee] text-2xl font-semibold shrink-0">10%</span>
      </div>
    </div>
  </div>

</div>

<!-- PILARES -->
<div class="border-y border-black/10 dark:border-[#feffee]/10">
  <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-black/10 dark:divide-[#feffee]/10">
    <div class="px-6 md:px-10 py-10 md:py-12">
      <p class="text-black/20 dark:text-[#feffee]/20 text-5xl md:text-6xl font-semibold mb-6">01</p>
      <p class="text-black/50 dark:text-[#feffee]/50 text-xs tracking-[.18em] uppercase mb-3">Creadorxs</p>
      <p class="text-black/70 dark:text-[#feffee]/70 text-[15px] leading-relaxed">Tu perfil con música, fotos, diario, artículos y film.</p>
    </div>
    <div class="px-6 md:px-10 py-10 md:py-12">
      <p class="text-black/20 dark:text-[#feffee]/20 text-5xl md:text-6xl font-semibold mb-6">02</p>
      <p class="text-black/50 dark:text-[#feffee]/50 text-xs tracking-[.18em] uppercase mb-3">Eventos</p>
      <p class="text-black/70 dark:text-[#feffee]/70 text-[15px] leading-relaxed">Boletería propia para tus conciertos y presentaciones.</p>
    </div>
    <div class="px-6 md:px-10 py-10 md:py-12">
      <p class="text-black/20 dark:text-[#feffee]/20 text-5xl md:text-6xl font-semibold mb-6">03</p>
      <p class="text-black/50 dark:text-[#feffee]/50 text-xs tracking-[.18em] uppercase mb-3">Merca</p>
      <p class="text-black/70 dark:text-[#feffee]/70 text-[15px] leading-relaxed">Vende tus productos físicos dentro del ecosistema.</p>
    </div>
  </div>
</div>

<!-- CÓMO FUNCIONA -->
<div class="px-6 md:px-14 py-14 md:py-28 border-b border-black/10 dark:border-[#feffee]/10">
  <p class="text-black/50 dark:text-[#feffee]/50 text-xs tracking-[.2em] uppercase mb-4 md:mb-6">Cómo funciona</p>
  <h2 class="text-3xl md:text-6xl font-semibold text-black dark:text-[#feffee] mb-10 md:mb-16">Tres pasos.</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-16">
    <div>
      <p class="text-black/40 dark:text-[#feffee]/40 text-sm mb-3">01 —</p>
      <h3 class="text-black dark:text-[#feffee] text-xl font-semibold mb-2">Creas tu perfil</h3>
      <p class="text-black/60 dark:text-[#feffee]/60 text-[15px] leading-relaxed">Gratis. Sin tarjeta ni trámites.</p>
    </div>
    <div>
      <p class="text-black/40 dark:text-[#feffee]/40 text-sm mb-3">02 —</p>
      <h3 class="text-black dark:text-[#feffee] text-xl font-semibold mb-2">Primer mes gratis</h3>
      <p class="text-black/60 dark:text-[#feffee]/60 text-[15px] leading-relaxed">Acceso completo para explorar y llenar tu perfil.</p>
    </div>
    <div>
      <p class="text-black/40 dark:text-[#feffee]/40 text-sm mb-3">03 —</p>
      <h3 class="text-black dark:text-[#feffee] text-xl font-semibold mb-2">Pagas solo si actualizas</h3>
      <p class="text-black/60 dark:text-[#feffee]/60 text-[15px] leading-relaxed">$20.000 cada tres meses para subir contenido nuevo. Tu perfil nunca desaparece.</p>
    </div>
  </div>
</div>

<!-- TARIFAS -->
<div id="tarifas" class="px-6 md:px-14 py-14 md:py-28 border-b border-black/10 dark:border-[#feffee]/10">
  <p class="text-black/50 dark:text-[#feffee]/50 text-xs tracking-[.2em] uppercase mb-4 md:mb-6">Tarifas</p>
  <h2 class="text-3xl md:text-6xl font-semibold text-black dark:text-[#feffee] mb-10 md:mb-16">Lo que cuesta.</h2>
  <div class="w-full border-t border-black/10 dark:border-[#feffee]/10">
    <div class="flex justify-between items-center py-5 border-b border-black/10 dark:border-[#feffee]/10 gap-4">
      <div class="min-w-0">
        <span class="text-black dark:text-[#feffee] text-lg md:text-xl">Crear perfil</span>
        <span class="ml-2 inline-block text-[10px] tracking-[.1em] uppercase bg-black/10 dark:bg-[#feffee]/10 text-black/60 dark:text-[#feffee]/60 px-2 py-0.5 rounded">Siempre gratis</span>
      </div>
      <span class="text-black dark:text-[#feffee] text-xl md:text-2xl font-semibold shrink-0">$0</span>
    </div>
    <div class="flex justify-between items-center py-5 border-b border-black/10 dark:border-[#feffee]/10 gap-4">
      <div class="min-w-0">
        <span class="text-black dark:text-[#feffee] text-lg md:text-xl">Primer mes</span>
        <span class="ml-2 inline-block text-[10px] tracking-[.1em] uppercase bg-black/10 dark:bg-[#feffee]/10 text-black/60 dark:text-[#feffee]/60 px-2 py-0.5 rounded">Gratis</span>
      </div>
      <span class="text-black dark:text-[#feffee] text-xl md:text-2xl font-semibold shrink-0">$0</span>
    </div>
    <div class="flex justify-between items-center py-5 border-b border-black/10 dark:border-[#feffee]/10 gap-4">
      <div class="min-w-0">
        <span class="text-black dark:text-[#feffee] text-lg md:text-xl">Subir contenido</span>
        <span class="block text-black/40 dark:text-[#feffee]/40 text-sm mt-0.5">cada 3 meses</span>
      </div>
      <span class="text-black dark:text-[#feffee] text-xl md:text-2xl font-semibold shrink-0">$20.000</span>
    </div>
    <div class="flex justify-between items-center py-5 border-b border-black/10 dark:border-[#feffee]/10 gap-4">
      <div class="min-w-0">
        <span class="text-black dark:text-[#feffee] text-lg md:text-xl">Boletería</span>
        <span class="block text-black/40 dark:text-[#feffee]/40 text-sm mt-0.5">por tiquete vendido</span>
      </div>
      <span class="text-black dark:text-[#feffee] text-xl md:text-2xl font-semibold shrink-0">10%</span>
    </div>
    <div class="flex justify-between items-center py-5 gap-4">
      <div class="min-w-0">
        <span class="text-black dark:text-[#feffee] text-lg md:text-xl">Merca</span>
        <span class="block text-black/40 dark:text-[#feffee]/40 text-sm mt-0.5">por producto vendido</span>
      </div>
      <span class="text-black dark:text-[#feffee] text-xl md:text-2xl font-semibold shrink-0">10%</span>
    </div>
  </div>
</div>

<!-- PARA ENTRAR -->
<div id="entrar" class="px-6 md:px-14 py-14 md:py-28 border-b border-black/10 dark:border-[#feffee]/10">
  <p class="text-black/50 dark:text-[#feffee]/50 text-xs tracking-[.2em] uppercase mb-4 md:mb-6">Para entrar</p>
  <h2 class="text-3xl md:text-6xl font-semibold text-black dark:text-[#feffee] mb-10 md:mb-16">¿Es para ti?</h2>
  <div class="flex flex-col gap-3">
    <div class="flex gap-4 items-start border border-black/10 dark:border-[#feffee]/10 px-5 md:px-6 py-5 md:py-6 hover:border-black/30 dark:hover:border-[#feffee]/30 transition-colors rounded-xl">
      <span class="text-black/30 dark:text-[#feffee]/30 text-xl md:text-2xl font-semibold shrink-0 leading-none mt-1">I</span>
      <div>
        <p class="text-black dark:text-[#feffee] text-xs tracking-[.1em] uppercase font-semibold mb-1">Eres creador activo</p>
        <p class="text-black/60 dark:text-[#feffee]/60 text-[15px]">Músico, fotógrafo, cineasta, escritor, artista visual.</p>
      </div>
    </div>
    <div class="flex gap-4 items-start border border-black/10 dark:border-[#feffee]/10 px-5 md:px-6 py-5 md:py-6 hover:border-black/30 dark:hover:border-[#feffee]/30 transition-colors rounded-xl">
      <span class="text-black/30 dark:text-[#feffee]/30 text-xl md:text-2xl font-semibold shrink-0 leading-none mt-1">II</span>
      <div>
        <p class="text-black dark:text-[#feffee] text-xs tracking-[.1em] uppercase font-semibold mb-1">Tienes algo que mostrar</p>
        <p class="text-black/60 dark:text-[#feffee]/60 text-[15px]">No necesitas un portafolio perfecto, con algo real es suficiente.</p>
      </div>
    </div>
    <div class="flex gap-4 items-start border border-black/10 dark:border-[#feffee]/10 px-5 md:px-6 py-5 md:py-6 hover:border-black/30 dark:hover:border-[#feffee]/30 transition-colors rounded-xl">
      <span class="text-black/30 dark:text-[#feffee]/30 text-xl md:text-2xl font-semibold shrink-0 leading-none mt-1">III</span>
      <div>
        <p class="text-black dark:text-[#feffee] text-xs tracking-[.1em] uppercase font-semibold mb-1">Piensas a largo plazo</p>
        <p class="text-black/60 dark:text-[#feffee]/60 text-[15px]">Roxaaanne es para construir una carrera, no para vender un solo evento.</p>
      </div>
    </div>
  </div>
</div>

<!-- CTA FINAL -->
<div class="px-6 md:px-14 py-20 md:py-40 text-center">
  <h2 class="text-[14vw] md:text-[7vw] font-semibold leading-[.95] text-black dark:text-[#feffee] mb-5 md:mb-6">
    ¿navegamos?
  </h2>
  <p class="text-black/60 dark:text-[#feffee]/60 text-base md:text-[17px] max-w-[340px] mx-auto mb-8 md:mb-10">
    escríbenos y arrancamos juntos
  </p>
  <a href="mailto:{{ section.settings.email }}" class="inline-block bg-black dark:bg-[#feffee] text-[#feffee] dark:text-black text-xl md:text-2xl font-semibold px-10 md:px-12 py-4 md:py-5 hover:opacity-80 transition-opacity rounded-xl">
    subirme a bordo
  </a>
</div>

{% schema %}
{
  "name": "Para Creadorxs",
  "tag": "section",
  "class": "section precios",
  "settings": [
    {
      "type": "text",
      "id": "email",
      "label": "Email de contacto",
      "default": "hola@roxaaanne.com"
    }
  ],
  "presets": [
    {
      "name": "Para Creadorxs",
      "category": "Custom"
    }
  ]
}
{% endschema %}
