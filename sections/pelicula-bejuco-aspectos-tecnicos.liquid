<!-- Demo styles -->
<style>
  .swiper {
    width: 100%;
    height: 360px;
    /* altura por defecto (móvil) */
  }

  @media (min-width: 768px) {
    .swiper {
      height: 480px;
    }
  }

  @media (min-width: 1024px) {
    .swiper {
      height: 600px;
    }
  }

  .swiper-slide {
    text-align: center;
    font-size: 18px;
    background: #fff;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .swiper-slide img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Pagination bullets styling */
  .swiper-pagination {
    bottom: 12px;
    text-align: center;
    z-index: 20;
  }

  .swiper-pagination-bullet {
    width: 10px;
    height: 10px;
    background: #DED49E;
    opacity: 0.6;
    border-radius: 50%;
    margin: 0 6px !important;
  }

  .swiper-pagination-bullet-active {
    opacity: 1;
    transform: scale(1.15);
    background: #DED49E;
  }
</style>

<div class="bg-[#000]">
  <div class="md:container md:mx-auto">
    <h1 class="text-[#DED49E] text-bejuco text-[50px] text-center pt-12 mb-4">{{ section.settings.title }}</h1>
    <p class="hidden">{{ section.settings.description }}</p>
    <div class="swiper mySwiperAspectosTecnicos">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          {% if block.settings.image %}
            <div class="swiper-slide">
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="Slide"
                class="w-full h-full object-cover">
            </div>
          {% endif %}
        {% endfor %}
      </div>
      <div class="swiper-pagination"></div>
    </div>
  </div>
</div>


<!-- Initialize Swiper (scoped to this section) -->
<script>
  (function(){
    var script = document.currentScript;
    var root = script && script.previousElementSibling;
    while (root && root.nodeType !== 1) root = root.previousElementSibling;
    var swiperEl = root && root.classList && root.classList.contains('swiper') ? root : (root && root.querySelector ? root.querySelector('.mySwiperAspectosTecnicos') : null);
    if (!swiperEl) return;

    new Swiper(swiperEl, {
      slidesPerView: 1.2,
      spaceBetween: 16,
      freeMode: true,
      grabCursor: true,
      pagination: {
        el: swiperEl.querySelector('.swiper-pagination'),
        dynamicBullets: true,
        clickable: true
      },
      breakpoints: {
        768: { slidesPerView: 2.2 },
        1024: { slidesPerView: 3.5 }
      }
    });
  })();
</script>

{% schema %}
  {
    "name": "Swiper Aspectos Técnicos",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Título",
        "default": "Aspectos Técnicos"
      }, {
        "type": "textarea",
        "id": "description",
        "label": "Descripción",
        "default": "Agrega aquí una breve descripción de los aspectos técnicos."
      }
    ],
    "blocks": [
      {
        "type": "slide",
        "name": "Slide de imagen",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Imagen del slide"
          }
        ]
      }
    ],
    "max_blocks": 20
  }
{% endschema %}


<script>



  (function () {

  const init = () => {
    const title = document.querySelector('[data-testid="download-brochure-page_download-brochure-title"]');
    if (!title || document.querySelector('.custom-brochure-banner')) return;

    title.textContent = "Begin your journey with the programme brochure";

    const firstParagraph = document.querySelector('#Programme-calendar p');
    if (firstParagraph) {
      firstParagraph.textContent = "Thank you for your interest in our programme.";
    }

    const banner = document.createElement("section");
    banner.className = "custom-brochure-banner";

    banner.innerHTML = `
      <div class="custom-brochure-inner">
        <h3 class="custom-brochure-title">In the brochure you'll find:</h3>
        <ul class="custom-brochure-list">
          <li>More information about the programme content and structure.</li>
          <li>Details on who attends this programme.</li>
          <li>How the programme will benefit you.</li>
        </ul>
      </div>
    `;

    title.parentNode.insertBefore(banner, title.nextSibling);

    if (!document.querySelector('#custom-brochure-styles')) {
      const style = document.createElement("style");
      style.id = "custom-brochure-styles";
      style.innerHTML = `
        .custom-brochure-banner {
          background-color: #0B2A6F;
          color: white;
          width: 100%;
          margin: 40px 0;
        }

        .custom-brochure-inner {
          padding: 20px;
          max-width: 1100px;
        }

        .custom-brochure-title {
          font-family: 'Montserrat', sans-serif;
          font-weight: 700;
          font-size: 18px;
          margin-bottom: 5px;
        }

        #Programme-calendar p {
          font-size: 18px;
        }

        .custom-brochure-list {
          list-style: disc;
          padding-left: 24px;
          margin: 0;
        }

        .custom-brochure-list li {
          font-size: 16px;
          line-height: 18px;
          margin-bottom: 5px;
        }
      `;
      document.head.appendChild(style);
    }

    observer.disconnect();
  };

  const observer = new MutationObserver(init);
  observer.observe(document.body, { childList: true, subtree: true });

  init();

  })();

</script>