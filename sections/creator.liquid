<div class="container mx-auto px-10 md:px-0">
  <div class="flex justify-center items-center flex-col gap-12 md:flex-col">
    <div class="w-full flex justify-center md:w-1/3">
      <div class="w-[170px] h-[170px] rounded-full overflow-hidden md:mt-12">
        {% if section.settings.image %}
          <img
            class="w-full h-full object-cover"
            src="{{ section.settings.image | image_url }}"
            alt="{{ section.settings.name | escape }}">
        {% endif %}
      </div>
    </div>
    <div class="mt-2 text-center flex flex-col justifu-center items-center">
      <h1 class="text-black dark:text-[#feffee] text-[40px] md:text-[40px] tracking-[-1px] md:tracking-[-2px] font-[400]">{{ section.settings.name }}</h1>
      <div class="w-full md:w-2/3 text-[17px] leading-[20px] md:text-3xl font-[300] mt-1 text-black dark:text-[#feffee]">{{ section.settings.description }}</div>
    </div>
  </div>
</div>

<div class="container mx-auto mt-12 grid grid-cols-1 md:grid-cols-2 px-8 md:px-0">
  {% for block in section.blocks %}
    <a href="{{ block.settings.link }}" data-creator-link="{{ block.settings.link }}" class="roxy-creator-block relative border-2 border-black dark:border-[#feffee] border dark:border-opacity-50 rounded-lg text-black dark:text-[#feffee] text-[23px] tracking-[-0.3px] font-[400] hover:font-[400] hover:bg-black hover:dark:bg-[#080808] hover:text-[#feffee] hover:border-2 min-h-[200px] flex justify-center items-center gap-3">
      <span class="roxy-creator-playing" style="display:none;align-items:center;gap:6px;color:#FFDD00;">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><polygon points="2,1 13,7 2,13"/></svg>
      </span>
      {{ block.settings.title }}
    </a>
  {% endfor %}
</div>

{%- if section.settings.collection -%}
  {%- assign creator_col = section.settings.collection -%}
  <div class="container mx-auto mt-16 px-8 md:px-0">

    {%- if section.settings.products_title != blank -%}
      <h2 class="text-black dark:text-[#feffee] text-[28px] tracking-[-0.5px] font-[400] mb-6">
        {{ section.settings.products_title }}
      </h2>
    {%- endif -%}

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {%- for product in creator_col.products limit: section.settings.products_count -%}
        <a href="{{ product.url }}" class="group flex flex-col gap-3">
          <div class="rounded-xl overflow-hidden bg-[#f2f2f2] dark:bg-[#1a1a1a]" style="aspect-ratio:1/1;">
            {%- if product.featured_image -%}
              <img
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | escape }}"
                loading="lazy"
                width="600"
                height="600">
            {%- else -%}
              <div class="w-full h-full flex items-center justify-center opacity-20">
                <svg
                  width="40"
                  height="40"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"><rect
                    x="3"
                    y="3"
                    width="18"
                    height="18"
                    rx="2" /><path d="M3 9l4-4 4 4 4-4 4 4" /><circle
                    cx="8.5"
                    cy="13.5"
                    r="1.5" /></svg>
              </div>
            {%- endif -%}
          </div>
          <div class="flex flex-col gap-1 px-1">
            <span class="text-black dark:text-[#feffee] text-sm font-[500] leading-tight line-clamp-2">
              {{ product.title }}
            </span>
            <span class="text-black/50 dark:text-[#feffee]/50 text-sm">
              {%- if product.compare_at_price > product.price -%}
                <span class="line-through mr-1 text-xs opacity-60">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
              {{ product.price | money }}
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- if creator_col.products_count > section.settings.products_count -%}
      <div class="mt-10 flex justify-center">
        <a href="{{ creator_col.url }}" class="border border-black dark:border-[#feffee] dark:border-opacity-50 text-black dark:text-[#feffee] text-sm px-8 py-3 rounded-lg hover:bg-black hover:text-[#feffee] dark:hover:bg-[#feffee] dark:hover:text-black transition-colors duration-200">
          Ver todos los productos
        </a>
      </div>
    {%- endif -%}

  </div>
{%- endif -%}


<script>
  function roxyCreatorSync(articleUrl) {
    document.querySelectorAll('.roxy-creator-block').forEach(function(el) {
      var link = el.getAttribute('data-creator-link') || '';
      var isPlaying = articleUrl && link && (articleUrl === link || articleUrl.startsWith(link));
      var indicator = el.querySelector('.roxy-creator-playing');
      if (indicator) indicator.style.display = isPlaying ? 'flex' : 'none';
    });
  }
  window.addEventListener('roxy:playing-article', function(e) {
    roxyCreatorSync(e.detail.articleUrl || '');
  });
  // Sync on page load if player already has a queue
  document.addEventListener('DOMContentLoaded', function() {
    if (window.RP && RP.articleUrl) roxyCreatorSync(RP.articleUrl);
  });
</script>

{% schema %}
  {
    "name": "Custom Blocks",
    "settings": [
      {
        "type": "image_picker",
        "id": "image",
        "label": "Imagen"
      },
      {
        "type": "text",
        "id": "name",
        "label": "Nombre",
        "default": "Nombre de ejemplo"
      },
      {
        "type": "richtext",
        "id": "description",
        "label": "Descripción"
      },
      {
        "type": "header",
        "content": "Productos"
      }, {
        "type": "collection",
        "id": "collection",
        "label": "Colección de productos"
      }, {
        "type": "text",
        "id": "products_title",
        "label": "Título de la sección de productos",
        "default": "merca"
      }, {
        "type": "range",
        "id": "products_count",
        "label": "Cantidad de productos a mostrar",
        "min": 2,
        "max": 16,
        "step": 2,
        "default": 8
      }
    ],
    "blocks": [
      {
        "type": "products",
        "name": "Productos",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Productos"
          }, {
            "type": "richtext",
            "id": "description",
            "label": "Description"
          }, {
            "type": "collection",
            "id": "content",
            "label": "Lista de productos"
          }
        ]
      }, {
        "type": "blog",
        "name": "Blog",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "Título",
            "default": "Imágenes / Películas / Artículos"
          }, {
            "type": "richtext",
            "id": "description",
            "label": "Description"
          }, {
            "type": "blog",
            "id": "content",
            "label": "Seleccionar Blog"
          }
        ]
      }, {
        "type": "section",
        "name": "Section",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "Titulo"
          }, {
            "type": "url",
            "id": "link",
            "label": "Link"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Sección de Bloques",
        "category": "Custom",
        "blocks": [
          {
            "type": "products"
          }, {
            "type": "blog"
          }
        ]
      }
    ]
  }
{% endschema %}