<div class="container mx-auto px-7 md:px-0 mt-10">
  <h2 class="text-[27px] md:text-[40px] text-black dark:text-[#feffee] font-medium mb-2 tracking-tight mt-8">lo nuestro</h2>

  <div class="relative">
    <div class="flex gap-6 overflow-x-auto pb-4 scrollbar-custom snap-x snap-mandatory scroll-container-{{ section.id }}">
      {% for block in section.blocks %}
        {% if block.type == 'image_link' %}
          <a
            href="{{ block.settings.link | default: '#' }}"
            class="flex-shrink-0 w-[200px] md:w-[250px] group snap-start no-underline rounded-xl overflow-hidden border-2 border-[#c9c9c9] dark:border-[#5a5a5a] hover:border-[#feffee] dark:hover:border-[#feffee] transition-all duration-300 bg-[#feffee] dark:bg-[#1c1c1c]"
            {{ block.shopify_attributes }}>
            {% if block.settings.image %}
              <img
                src="{{ block.settings.image | image_url: width: 500 }}"
                alt="{{ block.settings.name | escape }}"
                width="500"
                height="750"
                class="w-full h-auto aspect-[2/3] object-cover">
            {% endif %}
            <div class="px-3 py-3">
              {% if block.settings.name != blank %}
                <h3 class="text-[15px] md:text-[17px] font-semibold text-black dark:text-[#feffee] text-center">{{ block.settings.name }}</h3>
              {% endif %}
              {% if block.settings.date != blank %}
                <p class="text-[13px] text-gray-500 dark:text-[#9e9e9e] text-center mt-1">{{ block.settings.date }}</p>
              {% endif %}
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <style>
    .scrollbar-custom::-webkit-scrollbar { height: 8px; }
    .scrollbar-custom::-webkit-scrollbar-track { background: transparent; border-radius: 10px; }
    .scrollbar-custom::-webkit-scrollbar-thumb { background: #c9c9c9; border-radius: 10px; border: 2px solid #c9c9c9; }
    .dark .scrollbar-custom::-webkit-scrollbar-thumb { background: #5a5a5a; border: 2px solid #5a5a5a; }
    .scrollbar-custom::-webkit-scrollbar-thumb:hover { background: #a0a0a0; }
    .dark .scrollbar-custom::-webkit-scrollbar-thumb:hover { background: #757575; }
  </style>
</div>

{% schema %}
  {
    "name": "Cinergia Lo Nuestro",
    "settings": [],
    "blocks": [
      {
        "type": "image_link",
        "name": "Imagen con enlace",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Imagen"
          }, {
            "type": "url",
            "id": "link",
            "label": "Enlace"
          }, {
            "type": "text",
            "id": "name",
            "label": "Nombre"
          }, {
            "type": "text",
            "id": "date",
            "label": "Fecha"
          }
        ]
      }, {
        "type": "content",
        "name": "Contenido",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "Título"
          }, {
            "type": "richtext",
            "id": "content",
            "label": "Contenido"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Cinergia Lo Nuestro"
      }
    ]
  }
{% endschema %}