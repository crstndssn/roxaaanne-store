<style>
  .rfu-section { background: #0a0a0a; padding: 80px 0; }

  .rfu-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .rfu-eyebrow {
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(255,255,255,0.35); margin-bottom: 12px;
  }
  .rfu-title {
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 400; letter-spacing: -1px;
    color: #fff; margin: 0 0 8px;
  }
  .rfu-address {
    font-size: 15px;
    color: rgba(255,255,255,0.45);
  }

  .rfu-map-wrap {
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    background: #1a1a1a;
  }
  .rfu-map-wrap iframe {
    display: block;
    width: 100%;
    border: none;
  }

  .rfu-info-row {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 24px;
    justify-content: center;
  }
  .rfu-info-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 100px;
    padding: 10px 18px;
    color: rgba(255,255,255,0.7);
    font-size: 13px;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .rfu-info-pill:hover {
    background: rgba(255,255,255,0.1);
    color: #fff;
  }
  .rfu-info-pill svg { flex-shrink: 0; }
</style>

<section class="rfu-section">
  <div class="container mx-auto px-6 md:px-8">

    <div class="rfu-header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="rfu-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="rfu-title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.address != blank -%}
        <p class="rfu-address">{{ section.settings.address }}</p>
      {%- endif -%}
    </div>

    {%- if section.settings.map_embed_url != blank -%}
      <div class="rfu-map-wrap">
        <iframe
          src="{{ section.settings.map_embed_url }}"
          height="{{ section.settings.map_height }}"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="{{ section.settings.title | escape }}">
        </iframe>
      </div>
    {%- else -%}
      <div class="rfu-map-wrap" style="height:{{ section.settings.map_height }}px; display:flex; align-items:center; justify-content:center;">
        <p style="color:rgba(255,255,255,0.25); font-size:14px;">Agrega la URL del embed de Google Maps en los ajustes</p>
      </div>
    {%- endif -%}

    <!-- Pills de info -->
    <div class="rfu-info-row">
      {%- if section.settings.address != blank -%}
        <a
          href="https://www.google.com/maps/search/{{ section.settings.address | url_encode }}"
          target="_blank"
          rel="noopener"
          class="rfu-info-pill">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          {{ section.settings.address }}
        </a>
      {%- endif -%}
      {%- if section.settings.date != blank -%}
        <span class="rfu-info-pill">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          {{ section.settings.date }}
        </span>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Fest — Ubicación",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto pequeño",
      "placeholder": "ej: Venue"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "¿Dónde?"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Dirección",
      "placeholder": "ej: Foro Sol, CDMX"
    },
    {
      "type": "text",
      "id": "date",
      "label": "Fecha / hora",
      "placeholder": "ej: Sábado 14 de junio · 18:00 hrs"
    },
    {
      "type": "header",
      "content": "Google Maps"
    },
    {
      "type": "text",
      "id": "map_embed_url",
      "label": "URL del embed de Google Maps",
      "info": "Google Maps → Compartir → Incorporar un mapa → copia solo el valor src del iframe"
    },
    {
      "type": "range",
      "id": "map_height",
      "label": "Altura del mapa (px)",
      "min": 300,
      "max": 700,
      "step": 50,
      "default": 450
    }
  ],
  "presets": [{ "name": "Fest Ubicación" }]
}
{% endschema %}
