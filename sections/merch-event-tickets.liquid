<section class="event-tickets">
  {% if section.settings.heading != blank %}
    <h2>{{ section.settings.heading }}</h2>
  {% endif %}
  <a href="{{ section.settings.button_url }}" class="btn">
    {{ section.settings.button_label | default: 'Get tickets' }}
  </a>
</section>

{% schema %}
{
  "name": "Event Tickets",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tickets" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Get tickets" },
    { "type": "url", "id": "button_url", "label": "Button URL" }
  ],
  "presets": [{ "name": "Event Tickets" }]
}
{% endschema %}