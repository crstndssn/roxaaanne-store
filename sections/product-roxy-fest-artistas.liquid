<style>
  .rfa-section { background: #0a0a0a; padding: 80px 0; }

  .rfa-header {
    text-align: center;
    margin-bottom: 56px;
  }
  .rfa-eyebrow {
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(255,255,255,0.35); margin-bottom: 12px;
  }
  .rfa-section-title {
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 400; letter-spacing: -1.5px;
    color: #fff; margin: 0;
  }

  /* Artist grid */
  .rfa-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px 32px;
    margin-bottom: 56px;
  }

  .rfa-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    transition: opacity 0.3s ease;
    opacity: 1;
    max-width: 120px;
    text-align: center;
    -webkit-tap-highlight-color: transparent;
  }
  .rfa-item.dimmed { opacity: 0.8; }

  .rfa-avatar {
    width: 90px; height: 90px;
    border-radius: 50%;
    overflow: hidden;
    background: #1e1e1e;
    border: 2px solid transparent;
    transition: border-color 0.25s, transform 0.2s;
    flex-shrink: 0;
  }
  .rfa-item.active .rfa-avatar {
    border-color: #fff;
    transform: scale(1.05);
  }
  .rfa-avatar img { width: 100%; height: 100%; object-fit: cover; }

  .rfa-name {
    font-size: 13px; font-weight: 600;
    color: rgba(255,255,255,0.65);
    transition: color 0.2s;
    line-height: 1.3;
  }
  .rfa-item.active .rfa-name { color: #fff; }

  /* Description panel */
  .rfa-desc-panel {
    max-width: 640px;
    margin: 0 auto;
    min-height: 80px;
    position: relative;
  }

  .rfa-desc-block {
    display: none;
    animation: rfaFadeIn 0.3s ease;
  }
  .rfa-desc-block.visible { display: block; }

  @keyframes rfaFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .rfa-desc-name {
    font-size: 22px; font-weight: 600;
    color: #fff; margin-bottom: 8px;
    letter-spacing: -0.3px;
  }
  .rfa-desc-text {
    font-size: 15px; line-height: 1.65;
    color: rgba(255,255,255,0.6);
  }
  .rfa-desc-text p { margin: 0 0 8px; }
  .rfa-desc-text p:last-child { margin: 0; }

  .rfa-general-text {
    font-size: 16px; line-height: 1.65;
    color: rgba(255,255,255,0.55);
    text-align: center;
  }
  .rfa-general-text p { margin: 0 0 8px; }
  .rfa-general-text p:last-child { margin: 0; }

  @media (max-width: 640px) {
    .rfa-grid { gap: 18px 20px; }
    .rfa-avatar { width: 72px; height: 72px; }
    .rfa-name { font-size: 12px; }
  }
</style>

<section class="rfa-section">
  <div class="container mx-auto px-6 md:px-8">

    <div class="rfa-header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="rfa-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="rfa-section-title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>

    <!-- Artist avatars -->
    <div class="rfa-grid" id="rfa-grid">
      {%- for block in section.blocks -%}
        <div
          class="rfa-item"
          data-idx="{{ forloop.index0 }}"
          id="rfa-item-{{ forloop.index0 }}"
          onclick="rfaSelect({{ forloop.index0 }})"
          {{ block.shopify_attributes }}>
          <div class="rfa-avatar">
            {%- if block.settings.image -%}
              <img src="{{ block.settings.image | image_url: width: 200 }}"
                alt="{{ block.settings.name | escape }}"
                width="200" height="200">
            {%- endif -%}
          </div>
          <span class="rfa-name">{{ block.settings.name }}</span>
        </div>
      {%- endfor -%}
    </div>

    <!-- Description panel -->
    <div class="rfa-desc-panel" id="rfa-desc-panel">

      <!-- General text (default) -->
      <div class="rfa-desc-block visible" id="rfa-general">
        <div class="rfa-general-text">
          {{ section.settings.general_text }}
        </div>
      </div>

      <!-- Per-artist descriptions -->
      {%- for block in section.blocks -%}
        <div class="rfa-desc-block" id="rfa-desc-{{ forloop.index0 }}">
          <p class="rfa-desc-name">{{ block.settings.name }}</p>
          <div class="rfa-desc-text">{{ block.settings.description }}</div>
        </div>
      {%- endfor -%}

    </div>

  </div>
</section>

<script>
(function() {
  var current = null;

  window.rfaSelect = function(idx) {
    var items = document.querySelectorAll('.rfa-item');
    var general = document.getElementById('rfa-general');

    if (current === idx) {
      // Deselect → volver al texto general
      current = null;
      items.forEach(function(el) { el.classList.remove('active', 'dimmed'); });
      document.querySelectorAll('.rfa-desc-block').forEach(function(el) { el.classList.remove('visible'); });
      general.classList.add('visible');
      return;
    }

    current = idx;

    // Avatars: activo vs dimmed
    items.forEach(function(el) {
      var elIdx = parseInt(el.dataset.idx);
      el.classList.toggle('active', elIdx === idx);
      el.classList.toggle('dimmed', elIdx !== idx);
    });

    // Descripción
    document.querySelectorAll('.rfa-desc-block').forEach(function(el) { el.classList.remove('visible'); });
    var target = document.getElementById('rfa-desc-' + idx);
    if (target) target.classList.add('visible');
  };
})();
</script>

{% schema %}
{
  "name": "Fest — Artistas",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto pequeño",
      "placeholder": "ej: Line-up"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Artistas"
    },
    {
      "type": "richtext",
      "id": "general_text",
      "label": "Texto general (se muestra al cargar)",
      "default": "<p>Selecciona un artista para conocer más sobre él.</p>"
    }
  ],
  "blocks": [
    {
      "type": "artista",
      "name": "Artista",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Foto del artista"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre",
          "default": "Artista"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Descripción",
          "default": "<p>Descripción del artista.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fest Artistas",
      "blocks": [
        { "type": "artista" },
        { "type": "artista" },
        { "type": "artista" }
      ]
    }
  ]
}
{% endschema %}
