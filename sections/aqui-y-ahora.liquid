<section class="container mx-auto px-8 md:px-0 py-16">
  {% if section.settings.title != blank %}
    <h2 class="text-black dark:text-[#feffee] text-4xl md:text-5xl font-medium mb-4">{{ section.settings.title }}</h2>
  {% endif %}

  <div class="flex md:grid md:grid-cols-3 gap-5 overflow-x-auto md:overflow-x-visible pb-4 scrollbar-hide">
    {% for block in section.blocks %}
      {% if block.type == 'articulo' %}
        <div {{ block.shopify_attributes }} class="flex-shrink-0 w-[95vw] md:w-auto relative rounded-xl overflow-hidden border border-white/10 shadow-lg">
          {% if block.settings.url != blank %}
            <a href="{{ block.settings.url }}" class="block">
          {% else %}
            <div>
          {% endif %}

            {% if block.settings.image != blank %}
              <div class="w-full aspect-auto overflow-hidden">
                <img
                  src="{{ block.settings.image | image_url: width: 640 }}"
                  alt="{{ block.settings.title | escape }}"
                  class="w-full h-full object-contain"
                  loading="lazy">
              </div>
            {% endif %}

            <!-- Info bar debajo de la imagen (no sobrepuesta) -->
            <div class="mt-3 px-3 pb-3">
              <div class="flex items-center justify-between flex-nowrap bg-black/60 rounded-b-lg py-2 gap-4">
                <div class="flex gap-1 text-lg text-white/80 whitespace-nowrap">
                  {% if block.settings.creator_url != blank %}
                    creado por <a href="{{ block.settings.creator_url }}" class="font-bold underline text-white">{{ block.settings.creator }}</a>
                  {% else %}
                    creado por <span class="font-bold text-white">{{ block.settings.creator }}</span>
                  {% endif %}
                </div>
                <div class="text-white text-base font-semibold truncate text-left flex-1">
                  {% if block.settings.title != blank %}{{ block.settings.title }}{% endif %}
                </div>
              </div>
            </div>

          {% if block.settings.url != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

{% schema %}
{
  "name": "Aquí y Ahora",
  "tag": "section",
  "class": "section aqui-y-ahora",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "aquí y ahora"
    }
  ],
  "blocks": [
    {
      "type": "articulo",
      "name": "Artículo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        },
        {
          "type": "text",
          "id": "creator",
          "label": "Creador (nombre del perfil)",
          "default": "roxy fest"
        },
        {
          "type": "url",
          "id": "creator_url",
          "label": "URL del perfil del creador"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aquí y Ahora",
      "category": "Custom"
    }
  ]
}
{% endschema %}
