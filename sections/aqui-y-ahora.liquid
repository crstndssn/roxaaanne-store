<section class="container mx-auto px-8 md:px-0 py-16">
  {% if section.settings.title != blank %}
    <h2 class="text-black dark:text-[#feffee] text-4xl md:text-5xl font-medium mb-6">{{ section.settings.title }}</h2>
  {% endif %}

  <div class="flex md:grid md:grid-cols-3 gap-5 overflow-x-auto md:overflow-x-visible pb-4 scrollbar-hide">
    {% for block in section.blocks %}
      {% if block.type == 'articulo' %}
        <div {{ block.shopify_attributes }} class="flex-shrink-0 w-[95vw] md:w-auto">
          {% if block.settings.url != blank %}
            <a href="{{ block.settings.url }}" class="block bg-white/5 dark:bg-white/5 backdrop-blur-md border border-white/20 dark:border-white/10 rounded-xl overflow-hidden hover:border-black dark:hover:border-[#feffee] transition-all">
          {% else %}
            <div class="bg-white/5 dark:bg-white/5 backdrop-blur-md border border-white/20 dark:border-white/10 rounded-xl overflow-hidden">
          {% endif %}

            {% if block.settings.image != blank %}
              <div class="w-full aspect-auto overflow-hidden">
                <img
                  src="{{ block.settings.image | image_url: width: 640 }}"
                  alt="{{ block.settings.title | escape }}"
                  class="w-full h-full object-contain"
                  loading="lazy">
              </div>
            {% endif %}

            {% if block.settings.title != blank %}
              <div class="p-4">
                <h3 class="text-black dark:text-[#feffee] text-lg font-medium mb-2 line-clamp-2 text-left">{{ block.settings.title }}</h3>
              </div>
            {% endif %}

          {% if block.settings.url != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

{% schema %}
{
  "name": "Aquí y Ahora",
  "tag": "section",
  "class": "section aqui-y-ahora",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "aquí y ahora"
    }
  ],
  "blocks": [
    {
      "type": "articulo",
      "name": "Artículo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aquí y Ahora",
      "category": "Custom"
    }
  ]
}
{% endschema %}
