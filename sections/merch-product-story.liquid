<section class="product-story">
  {% if section.settings.heading != blank %}
    <h2>{{ section.settings.heading }}</h2>
  {% endif %}

  {% if section.settings.text != blank %}
    <div>{{ section.settings.text }}</div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Product Story",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    }
  ]
}
{% endschema %}