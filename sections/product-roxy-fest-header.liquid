<style>
  .rfh-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }
  @media (max-width: 767px) {
    .rfh-wrap { grid-template-columns: 1fr; gap: 24px; }
  }

  .rfh-gallery-main {
    aspect-ratio: 1/1;
    border-radius: 16px;
    overflow: hidden;
    background: #1a1a1a;
    position: relative;
  }
  .rfh-gallery-main img {
    width: 100%; height: 100%; object-fit: cover;
  }

  .rfh-thumbs {
    display: flex;
    gap: 8px;
    margin-top: 10px;
    flex-wrap: wrap;
  }
  .rfh-thumb {
    width: 60px; height: 60px;
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
    opacity: 0.55;
    transition: opacity 0.15s;
    border: 2px solid transparent;
    flex-shrink: 0;
  }
  .rfh-thumb.active { opacity: 1; border-color: #fff; }
  .rfh-thumb img { width: 100%; height: 100%; object-fit: cover; }

  .rfh-info { display: flex; flex-direction: column; gap: 20px; padding-top: 8px; }

  .rfh-vendor {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }

  .rfh-title {
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .rfh-price-wrap {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .rfh-price {
    font-size: 28px;
    font-weight: 700;
    color: #fff;
  }
  .rfh-price-compare {
    font-size: 18px;
    color: rgba(255,255,255,0.35);
    text-decoration: line-through;
  }
  .rfh-badge-sale {
    background: #cc0000;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 100px;
    letter-spacing: 0.06em;
  }

  .rfh-desc {
    font-size: 15px;
    line-height: 1.6;
    color: rgba(255,255,255,0.65);
  }
  .rfh-desc p { margin: 0 0 8px; }
  .rfh-desc p:last-child { margin: 0; }

  .rfh-variants label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 8px;
  }
  .rfh-variants select {
    width: 100%;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: 10px;
    color: #fff;
    font-size: 14px;
    padding: 12px 14px;
    appearance: none;
    cursor: pointer;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='7' viewBox='0 0 12 7' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l5 5 5-5' stroke='rgba(255,255,255,0.5)' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 14px center;
    padding-right: 36px;
  }
  .rfh-variants select:focus { outline: none; border-color: rgba(255,255,255,0.3); }

  .rfh-qty-wrap { display: flex; align-items: center; gap: 14px; }
  .rfh-qty-label {
    font-size: 12px; font-weight: 600; letter-spacing: 0.08em;
    text-transform: uppercase; color: rgba(255,255,255,0.5);
  }
  .rfh-qty {
    display: flex; align-items: center;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 10px; overflow: hidden;
  }
  .rfh-qty button {
    background: none; border: none; color: rgba(255,255,255,0.65);
    width: 38px; height: 38px; font-size: 18px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.12s;
  }
  .rfh-qty button:hover { background: rgba(255,255,255,0.08); color: #fff; }
  .rfh-qty input {
    width: 40px; text-align: center; background: none; border: none;
    color: #fff; font-size: 14px; font-weight: 600; padding: 0;
  }
  .rfh-qty input:focus { outline: none; }

  .rfh-btn-cart {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    width: 100%; padding: 16px 24px;
    background: #fff; color: #000;
    font-size: 15px; font-weight: 700;
    border: none; border-radius: 12px;
    cursor: pointer; transition: background 0.15s, transform 0.1s;
    text-decoration: none;
  }
  .rfh-btn-cart:hover { background: #e6e6e6; }
  .rfh-btn-cart:active { transform: scale(0.98); }
  .rfh-btn-cart:disabled { opacity: 0.5; cursor: not-allowed; }
  .rfh-btn-cart.loading { opacity: 0.7; pointer-events: none; }

  .rfh-unavailable {
    text-align: center; color: rgba(255,255,255,0.4);
    font-size: 14px; padding: 14px;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
  }

  .rfh-meta {
    display: flex; flex-direction: column; gap: 6px;
    padding-top: 8px;
    border-top: 1px solid rgba(255,255,255,0.07);
  }
  .rfh-meta span {
    font-size: 12px; color: rgba(255,255,255,0.35);
  }
  .rfh-meta strong { color: rgba(255,255,255,0.6); }
</style>

<div class="bg-black text-white">
  <div class="container mx-auto px-6 md:px-8 py-12 md:py-16">
    <div class="rfh-wrap">

      <!-- Galería -->
      <div>
        <div class="rfh-gallery-main" id="rfh-main-img">
          {%- if product.featured_image -%}
            <img id="rfh-main-img-el"
              src="{{ product.featured_image | image_url: width: 900 }}"
              alt="{{ product.featured_image.alt | escape }}"
              width="900" height="900">
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="rfh-thumbs">
            {%- for image in product.images -%}
              <div class="rfh-thumb {% if forloop.first %}active{% endif %}"
                data-src="{{ image | image_url: width: 900 }}"
                onclick="rfhSelectThumb(this)">
                <img src="{{ image | image_url: width: 120 }}" alt="{{ image.alt | escape }}">
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Info -->
      <div class="rfh-info">
        {%- if product.vendor != blank -%}
          <p class="rfh-vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="rfh-title">{{ product.title }}</h1>

        <div class="rfh-price-wrap" id="rfh-price-wrap">
          {%- assign current = product.selected_or_first_available_variant -%}
          {%- if current.compare_at_price > current.price -%}
            <span class="rfh-price-compare">{{ current.compare_at_price | money }}</span>
            <span class="rfh-price">{{ current.price | money }}</span>
            <span class="rfh-badge-sale">SALE</span>
          {%- else -%}
            <span class="rfh-price">{{ current.price | money }}</span>
          {%- endif -%}
        </div>

        {%- if product.description != blank -%}
          <div class="rfh-desc">{{ product.description }}</div>
        {%- endif -%}

        {%- form 'product', product, id: 'rfh-form', data-product-form: '' -%}
          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div class="rfh-variants">
                <label for="rfh-opt-{{ forloop.index }}">{{ option.name }}</label>
                <select id="rfh-opt-{{ forloop.index }}" name="option{{ forloop.index }}">
                  {%- for value in option.values -%}
                    <option value="{{ value }}" {% if option.selected_value == value %}selected{% endif %}>
                      {{ value }}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endfor -%}
            <input type="hidden" name="id" id="rfh-variant-id" value="{{ current.id }}">
          {%- else -%}
            <input type="hidden" name="id" value="{{ current.id }}">
          {%- endunless -%}

          <div class="rfh-qty-wrap">
            <span class="rfh-qty-label">Cantidad</span>
            <div class="rfh-qty">
              <button type="button" onclick="rfhQty(-1)">−</button>
              <input type="number" name="quantity" id="rfh-qty" value="1" min="1" max="99" readonly>
              <button type="button" onclick="rfhQty(1)">+</button>
            </div>
          </div>

          {%- if current.available -%}
            <button type="submit" id="rfh-btn-cart" class="rfh-btn-cart">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
              </svg>
              Agregar al carrito
            </button>
          {%- else -%}
            <p class="rfh-unavailable">Agotado</p>
          {%- endif -%}
        {%- endform -%}

        <div class="rfh-meta">
          {%- if product.type != blank -%}
            <span><strong>Tipo:</strong> {{ product.type }}</span>
          {%- endif -%}
          <span><strong>SKU:</strong> <span id="rfh-sku">{{ current.sku | default: '—' }}</span></span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function rfhQty(delta) {
    var el = document.getElementById('rfh-qty');
    el.value = Math.max(1, Math.min(99, parseInt(el.value) + delta));
  }
  function rfhSelectThumb(el) {
    document.querySelectorAll('.rfh-thumb').forEach(function(t) { t.classList.remove('active'); });
    el.classList.add('active');
    document.getElementById('rfh-main-img-el').src = el.dataset.src;
  }

  // Variant selection → update price + id + sku
  (function() {
    var form = document.getElementById('rfh-form');
    if (!form) return;
    var variants = {{ product.variants | json }};
    var selects = form.querySelectorAll('select[name^="option"]');
    if (!selects.length) return;

    selects.forEach(function(s) { s.addEventListener('change', updateVariant); });

    function updateVariant() {
      var opts = Array.from(selects).map(function(s) { return s.value; });
      var match = variants.find(function(v) {
        return v.options.every(function(o, i) { return o === opts[i]; });
      });
      if (!match) return;
      var vidEl = document.getElementById('rfh-variant-id');
      if (vidEl) vidEl.value = match.id;
      document.getElementById('rfh-sku').textContent = match.sku || '—';
    }
  })();

  // AJAX add to cart → open sidecart
  document.getElementById('rfh-form').addEventListener('submit', function(e) {
    e.preventDefault();
    var btn = document.getElementById('rfh-btn-cart');
    if (!btn) return;
    btn.classList.add('loading');
    btn.textContent = 'Agregando…';
    var data = new FormData(this);
    fetch('/cart/add.js', { method: 'POST', body: data })
      .then(function(r) { return r.json(); })
      .then(function() {
        btn.classList.remove('loading');
        btn.innerHTML = '✓ Agregado';
        setTimeout(function() {
          btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg> Agregar al carrito';
        }, 1500);
        if (typeof window.roxyOpenSidecart === 'function') window.roxyOpenSidecart();
      })
      .catch(function() {
        btn.classList.remove('loading');
        btn.textContent = 'Agregar al carrito';
      });
  });
</script>

{% schema %}
{
  "name": "Fest — Header",
  "tag": "section",
  "settings": [],
  "presets": [{ "name": "Fest Header" }]
}
{% endschema %}
