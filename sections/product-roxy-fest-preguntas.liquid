<style>
  .rfp-section { background: #0a0a0a; padding: 80px 0; }

  .rfp-header {
    margin-bottom: 48px;
  }
  .rfp-eyebrow {
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(255,255,255,0.35); margin-bottom: 12px;
  }
  .rfp-title {
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 400; letter-spacing: -1px;
    color: #fff; margin: 0;
  }

  .rfp-list {
    max-width: 720px;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .rfp-item {
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .rfp-question {
    width: 100%;
    background: none;
    border: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 22px 0;
    cursor: pointer;
    text-align: left;
    color: #fff;
    font-size: 16px;
    font-weight: 500;
    line-height: 1.4;
    transition: color 0.15s;
    -webkit-tap-highlight-color: transparent;
  }
  .rfp-question:hover { color: rgba(255,255,255,0.75); }

  .rfp-icon {
    flex-shrink: 0;
    width: 22px; height: 22px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    display: flex; align-items: center; justify-content: center;
    transition: border-color 0.2s, transform 0.3s;
    color: rgba(255,255,255,0.5);
  }
  .rfp-item.open .rfp-icon {
    border-color: rgba(255,255,255,0.5);
    transform: rotate(45deg);
    color: #fff;
  }

  .rfp-answer-wrap {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }
  .rfp-item.open .rfp-answer-wrap {
    grid-template-rows: 1fr;
  }
  .rfp-answer-inner {
    overflow: hidden;
  }
  .rfp-answer {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255,255,255,0.55);
    padding-bottom: 22px;
  }
  .rfp-answer p { margin: 0 0 10px; }
  .rfp-answer p:last-child { margin: 0; }
  .rfp-answer a {
    color: rgba(255,255,255,0.8);
    text-decoration: underline;
  }
</style>

<section class="rfp-section">
  <div class="container mx-auto px-6 md:px-8">

    <div class="rfp-header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="rfp-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="rfp-title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>

    <div class="rfp-list" id="rfp-list">
      {%- for block in section.blocks -%}
        <div class="rfp-item" id="rfp-item-{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          <button
            class="rfp-question"
            onclick="rfpToggle({{ forloop.index0 }})"
            aria-expanded="false"
            aria-controls="rfp-ans-{{ forloop.index0 }}">
            <span>{{ block.settings.question }}</span>
            <span class="rfp-icon">
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                <line x1="5" y1="1" x2="5" y2="9"/>
                <line x1="1" y1="5" x2="9" y2="5"/>
              </svg>
            </span>
          </button>
          <div class="rfp-answer-wrap" id="rfp-wrap-{{ forloop.index0 }}">
            <div class="rfp-answer-inner">
              <div class="rfp-answer" id="rfp-ans-{{ forloop.index0 }}">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
  function rfpToggle(idx) {
    var item = document.getElementById('rfp-item-' + idx);
    var btn  = item.querySelector('.rfp-question');
    var isOpen = item.classList.contains('open');

    {%- if section.settings.one_at_a_time -%}
    // Cerrar todos los demás
    document.querySelectorAll('.rfp-item.open').forEach(function(el) {
      el.classList.remove('open');
      el.querySelector('.rfp-question').setAttribute('aria-expanded', 'false');
    });
    {%- endif -%}

    if (!isOpen) {
      item.classList.add('open');
      btn.setAttribute('aria-expanded', 'true');
    } else {
      item.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    }
  }
</script>

{% schema %}
{
  "name": "Fest — Preguntas",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto pequeño",
      "placeholder": "ej: FAQ"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Preguntas frecuentes"
    },
    {
      "type": "checkbox",
      "id": "one_at_a_time",
      "label": "Cerrar las demás al abrir una",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "pregunta",
      "name": "Pregunta",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Pregunta",
          "default": "¿Cuál es la pregunta?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Respuesta",
          "default": "<p>Esta es la respuesta a la pregunta.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fest Preguntas",
      "blocks": [
        { "type": "pregunta" },
        { "type": "pregunta" },
        { "type": "pregunta" }
      ]
    }
  ]
}
{% endschema %}
