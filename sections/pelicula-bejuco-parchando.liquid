<!-- Demo styles -->
<style>

  .swiper {
    width: 100%;
    height: 360px;
  }

  @media (min-width: 768px) {
    .swiper {
      height: 480px;
    }
  }

  @media (min-width: 1024px) {
    .swiper {
      height: 600px;
    }
  }

  .swiper-slide {
    text-align: center;
    font-size: 18px;
    background: #fff;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .mySwiperParchando .swiper-slide {
    width: auto !important;
  }

  .mySwiperParchando .swiper-slide img {
    display: block;
    width: auto;
    height: 100%;
    object-fit: unset;
  }

  /* Pagination bullets styling */
  .swiper-pagination {
    bottom: 12px;
    text-align: center;
    z-index: 20;
  }

  .swiper-pagination-bullet {
    width: 10px;
    height: 10px;
    background: #DED49E;
    opacity: 0.6;
    border-radius: 50%;
    margin: 0 6px !important;
  }

  .swiper-pagination-bullet-active {
    opacity: 1;
    transform: scale(1.15);
    background: #DED49E;
  }
</style>

